<view class="page login-page">
  <view class="login-header">
    <view class="logo-placeholder">玩</view>
    <view class="product-name">玩伴空间</view>
    <view class="product-desc">创建活动、邀请好友、一起规划、记录 AA、上传照片</view>
  </view>

  <view class="section card login-card">
    <view class="card-title">活动协作空间</view>
    <view class="card-desc">围绕一次活动集中处理成员、行程、投票、账本和照片</view>
  </view>

  <view class="section login-actions">
    <button class="pm-native-button primary" loading="{{loading}}" bindtap="handleWxLogin">{{loading ? '登录中...' : '微信授权登录'}}</button>
    <button class="pm-native-button secondary" bindtap="goAccountLogin">手机号 / 邮箱登录</button>
    <view class="minor-actions">
      <view class="minor-link" bindtap="goRegister">注册账号</view>
      <view class="minor-divider"></view>
      <view class="minor-link" bindtap="goBack">暂不登录</view>
    </view>
  </view>

  <view class="dev-note" bindtap="chooseMockUser">本地开发：{{mockUserLabel}}，轻触可切换模拟身份</view>
</view>
