.login-page {
  padding-left: 48rpx;
  padding-right: 48rpx;
}

.login-header {
  padding-top: 70rpx;
  text-align: center;
}

.logo-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  margin: 0 auto;
  border-radius: 32rpx;
  background: var(--pm-primary-light);
  color: var(--pm-primary-dark);
  font-size: 42rpx;
  font-weight: 900;
}

.product-name {
  margin-top: 28rpx;
  color: var(--pm-text);
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.25;
}

.product-desc {
  max-width: 520rpx;
  margin: 18rpx auto 0;
  color: var(--pm-text-muted);
  font-size: 27rpx;
  line-height: 1.55;
}

.login-card {
  padding: 34rpx;
}

.card-title {
  color: var(--pm-text);
  font-size: 32rpx;
  font-weight: 800;
}

.card-desc {
  margin-top: 12rpx;
  color: var(--pm-text-muted);
  font-size: 26rpx;
  line-height: 1.55;
}

.login-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.minor-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  margin-top: 6rpx;
}

.minor-link {
  color: var(--pm-text-muted);
  font-size: 25rpx;
  font-weight: 700;
}

.minor-divider {
  width: 1rpx;
  height: 24rpx;
  background: var(--pm-border);
}

.dev-note {
  margin-top: 28rpx;
  color: #a5afa9;
  font-size: 22rpx;
  text-align: center;
}
