.login-page {
  min-height: 100vh;
  padding: 0 0 calc(env(safe-area-inset-bottom) + 32rpx);
}

.auth-main {
  width: calc(100% - 152rpx);
  max-width: 598rpx;
  margin: 0 auto;
  box-sizing: border-box;
}

.logo-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 194rpx;
  height: 194rpx;
  margin: 0 auto;
  border-radius: 48rpx;
  background: #ddf2e7;
  color: #246b58;
  font-size: 68rpx;
  font-weight: 800;
}

.login-card {
  box-sizing: border-box;
  width: 100%;
  min-height: 344rpx;
  margin-top: 74rpx;
  padding: 38rpx 40rpx;
  border: 1rpx solid #d7e5dc;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(13, 36, 26, 0.06);
}

.card-title {
  color: #14211a;
  font-size: 58rpx;
  font-weight: 800;
  line-height: 1.22;
}

.card-desc {
  margin-top: 46rpx;
  color: #66756c;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 42rpx;
}

.login-actions {
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
  gap: 28rpx;
  margin-top: 180rpx;
}

.login-actions .pm-native-button {
  width: 100%;
  box-sizing: border-box;
  min-height: 104rpx;
  border-radius: 26rpx;
  font-size: 32rpx;
}

.login-actions .pm-native-button.primary {
  background: #56aa82;
  box-shadow: 0 10rpx 32rpx rgba(13, 38, 26, 0.1);
}

.login-actions .pm-native-button.secondary {
  border-color: #56aa82;
  color: #246b58;
}

.minor-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 34rpx;
  margin-top: 18rpx;
}

.minor-link {
  color: #246b58;
  font-size: 30rpx;
  font-weight: 600;
}

.minor-link:last-child {
  color: #66756c;
}

.minor-divider {
  width: 1rpx;
  height: 36rpx;
  background: #d7e5dc;
}

.login-redirect-note {
  margin: 54rpx auto 0;
  color: #97a49c;
  font-size: 24rpx;
  line-height: 30rpx;
  text-align: center;
}

.dev-note {
  margin-top: 54rpx;
  color: #a5b0a9;
  font-size: 22rpx;
  text-align: center;
}
