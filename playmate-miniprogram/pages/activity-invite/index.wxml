<view class="page">
  <view wx:if="{{loading}}" class="section card stack">
    <view class="empty-title">正在打开邀请</view>
    <view class="empty-desc">正在读取活动邀请信息。</view>
  </view>

  <view wx:elif="{{errorMessage}}" class="section card stack">
    <view class="empty-title">邀请加载失败</view>
    <view class="empty-desc">{{errorMessage}}</view>
    <button class="pm-native-button primary" bindtap="retryLoad">重新加载</button>
    <button class="pm-native-button secondary" bindtap="goHome">返回首页</button>
  </view>

  <block wx:else>
    <view class="invite-card">
      <image wx:if="{{invite.coverUrl}}" class="invite-cover" src="{{invite.coverUrl}}" mode="aspectFill" />
      <view wx:else class="invite-cover default-hero"></view>
      <view class="invite-content">
        <view class="invite-eyebrow">朋友邀请你加入活动</view>
        <view class="pm-status {{invite.statusClass}}">{{invite.statusText}}</view>
        <view class="invite-title">{{invite.name}}</view>
        <view class="invite-meta">{{invite.typeText}} · {{invite.locationText}}</view>
        <view class="invite-date">{{invite.dateText}}</view>
      </view>
    </view>

    <view class="section card invite-snapshot">
      <view class="snapshot-item">
        <view class="snapshot-value">{{invite.memberCount}}</view>
        <view class="snapshot-label">已有成员</view>
      </view>
      <view class="snapshot-divider"></view>
      <view class="snapshot-item">
        <view class="snapshot-value">{{invite.creatorNickname || '玩伴用户'}}</view>
        <view class="snapshot-label">创建者</view>
      </view>
    </view>

    <view class="section card invite-info">
      <view class="section-title">活动信息</view>
      <view class="info-row">
        <view class="info-label">地点</view>
        <view class="info-value">{{invite.locationText}}</view>
      </view>
      <view class="info-row">
        <view class="info-label">创建者</view>
        <view class="info-value">{{invite.creatorNickname || '玩伴用户'}}</view>
      </view>
      <view class="info-row">
        <view class="info-label">成员</view>
        <view class="info-value">{{invite.memberCount}} 位</view>
      </view>
      <view class="description">{{invite.descriptionText}}</view>
      <view wx:if="{{invite.reason}}" class="reason">{{invite.reason}}</view>
    </view>

    <view class="section action-card card">
      <button wx:if="{{invite.joined}}" class="pm-native-button primary" bindtap="goDetail">进入活动</button>
      <button wx:elif="{{invite.canJoin}}" class="pm-native-button primary" loading="{{joining}}" bindtap="handleJoin">{{joining ? '加入中...' : '加入活动'}}</button>
      <button wx:else class="pm-native-button secondary" bindtap="goHome">返回首页</button>
      <view wx:if="{{!invite.joined && invite.canJoin}}" class="hint">加入后可以查看活动详情，并参与后续协作。</view>
    </view>
  </block>
</view>
