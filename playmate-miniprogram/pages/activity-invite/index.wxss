.hero-card {
  position: relative;
  height: 440rpx;
  margin-top: 8rpx;
  overflow: hidden;
  border-radius: 34rpx;
  background: #e9f5ef;
  box-shadow: 0 16rpx 42rpx rgba(47, 111, 94, 0.08);
}

.hero-cover {
  width: 100%;
  height: 100%;
}

.default-hero {
  background: linear-gradient(145deg, #e9f5ef 0%, #f6f8f5 48%, #f4e7b4 100%);
}

.hero-card::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 240rpx;
  background: linear-gradient(180deg, rgba(31, 42, 36, 0) 0%, rgba(31, 42, 36, 0.62) 100%);
}

.hero-content {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
  z-index: 1;
  color: #ffffff;
}

.status-pill {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #2f6f5e;
  font-size: 24rpx;
  font-weight: 600;
}

.invite-title {
  margin-top: 16rpx;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.25;
}

.invite-meta {
  margin-top: 10rpx;
  font-size: 26rpx;
  opacity: 0.92;
}

.section-title {
  color: #1f2a24;
  font-size: 32rpx;
  font-weight: 700;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 28rpx;
}

.info-label {
  flex: 0 0 116rpx;
  color: #6f7c75;
  font-size: 26rpx;
}

.info-value {
  flex: 1;
  color: #1f2a24;
  font-size: 28rpx;
  text-align: right;
}

.description {
  padding-top: 18rpx;
  border-top: 1rpx solid #e1e8e3;
  color: #6f7c75;
  font-size: 28rpx;
  line-height: 1.6;
}

.reason {
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: #f7eeee;
  color: #b64646;
  font-size: 26rpx;
}

.action-card {
  margin-top: 32rpx;
}

.hint {
  margin-top: 18rpx;
  color: #6f7c75;
  font-size: 24rpx;
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
}

.empty-desc {
  color: #6f7c75;
  font-size: 28rpx;
  line-height: 1.5;
}
