.invite-card {
  position: relative;
  overflow: hidden;
  min-height: 430rpx;
  margin-top: 8rpx;
  border-radius: 34rpx;
  background: var(--pm-primary-light);
  box-shadow: var(--pm-shadow-card);
}

.invite-cover {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.default-hero {
  background: radial-gradient(circle at 78% 20%, #f2b84b 0 34rpx, transparent 36rpx),
    linear-gradient(145deg, #e9f5ef 0%, #f6f8f5 46%, #f4e7b4 100%);
}

.invite-card::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 260rpx;
  background: linear-gradient(180deg, rgba(31, 42, 36, 0) 0%, rgba(31, 42, 36, 0.58) 100%);
}

.invite-content {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
  z-index: 1;
}

.invite-eyebrow {
  margin-bottom: 14rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 25rpx;
  font-weight: 700;
}

.invite-title {
  margin-top: 16rpx;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.22;
}

.invite-meta {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
}

.invite-date {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
}

.invite-snapshot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 30rpx;
}

.snapshot-item {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.snapshot-value {
  color: var(--pm-text);
  font-size: 32rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.snapshot-label {
  margin-top: 8rpx;
  color: var(--pm-text-muted);
  font-size: 23rpx;
}

.snapshot-divider {
  width: 1rpx;
  height: 56rpx;
  margin: 0 20rpx;
  background: var(--pm-border);
}

.invite-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 28rpx;
}

.info-label {
  flex: 0 0 116rpx;
  color: var(--pm-text-muted);
  font-size: 26rpx;
}

.info-value {
  flex: 1;
  color: var(--pm-text);
  font-size: 28rpx;
  text-align: right;
}

.description {
  padding-top: 18rpx;
  border-top: 1rpx solid var(--pm-border);
  color: var(--pm-text-muted);
  font-size: 28rpx;
  line-height: 1.6;
}

.reason {
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: var(--pm-danger-soft);
  color: var(--pm-danger);
  font-size: 26rpx;
}

.action-card {
  margin-top: 32rpx;
}

.hint {
  margin-top: 18rpx;
  color: var(--pm-text-muted);
  font-size: 24rpx;
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
}

.empty-desc {
  color: var(--pm-text-muted);
  font-size: 28rpx;
  line-height: 1.5;
}
