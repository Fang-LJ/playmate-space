<view class="page mine-page" style="--mine-safe-top: {{safeTop}}rpx;">
  <view class="mine-content">
    <view class="user-card" bindtap="handleProfileCardTap">
      <image wx:if="{{isLoggedIn && user.avatarUrl}}" class="user-avatar" src="{{user.avatarUrl}}" mode="aspectFill" />
      <view wx:else class="user-avatar user-avatar-placeholder">{{isLoggedIn ? '玩' : '未'}}</view>
      <view class="user-main">
        <view class="user-name">{{isLoggedIn ? user.nickname : '点击登录'}}</view>
        <view class="user-desc">{{isLoggedIn ? '已登录' : '登录后同步你的活动空间'}}</view>
      </view>
    </view>

    <block wx:if="{{isLoggedIn}}">
      <view class="function-card" bindtap="goActivities">
        <view>
          <view class="action-title">我的活动</view>
          <view class="action-desc">查看我创建和加入的活动</view>
        </view>
        <view class="action-arrow">›</view>
      </view>

      <view wx:if="{{!user.accountProtected}}" class="function-card reminder-card" bindtap="goAccountComplete">
        <view>
          <view class="action-title">账号保护未完成</view>
          <view class="action-desc">设置手机号或邮箱及密码，可使用其他方式登录</view>
        </view>
        <view class="action-arrow">›</view>
      </view>

      <view wx:if="{{showWechatProfileSuggestion}}" class="function-card reminder-card" bindtap="goWechatProfile">
        <view>
          <view class="action-title">完善微信资料</view>
          <view class="action-desc">设置头像、昵称或微信手机号</view>
        </view>
        <view class="action-arrow">›</view>
      </view>

      <view class="function-card" bindtap="goCreateActivity">
        <view>
          <view class="action-title">创建活动</view>
          <view class="action-desc">快速发起一次聚会或旅行</view>
        </view>
        <view class="action-arrow">›</view>
      </view>

      <view class="function-card version-card">
        <view class="action-title">版本信息</view>
        <view class="action-desc">玩伴空间 v1.0</view>
      </view>
    </block>

    <block wx:else>
      <view class="function-card" bindtap="goActivities">
        <view>
          <view class="action-title">我的活动</view>
          <view class="action-desc">登录后查看创建和加入的活动</view>
        </view>
        <view class="action-arrow">›</view>
      </view>

      <view class="function-card" bindtap="goCreateActivity">
        <view>
          <view class="action-title">创建活动</view>
          <view class="action-desc">登录后发起一次聚会或旅行</view>
        </view>
        <view class="action-arrow">›</view>
      </view>

      <view class="function-card version-card">
        <view class="action-title">版本信息</view>
        <view class="action-desc">玩伴空间 v1.0</view>
      </view>
    </block>
  </view>

  <view wx:if="{{isLoggedIn}}" class="mine-bottom-action">
    <button class="pm-native-button secondary bottom-action-button" bindtap="clearLogin">退出登录</button>
  </view>
  <view wx:else class="mine-bottom-action">
    <button class="pm-native-button primary bottom-action-button" bindtap="goLogin">微信授权登录</button>
  </view>
</view>
