<view class="page">
  <view class="page-title">我的</view>
  <view class="page-subtitle">{{isLoggedIn ? '管理你的活动和个人状态。' : '登录后可创建活动、加入朋友的活动空间。'}}</view>

  <view class="section card profile-card">
    <image wx:if="{{isLoggedIn && user.avatarUrl}}" class="avatar-image" src="{{user.avatarUrl}}" mode="aspectFill" />
    <view wx:else class="avatar-placeholder">{{isLoggedIn ? '玩' : '未'}}</view>
    <view class="profile-info">
      <view class="profile-name">{{isLoggedIn ? user.nickname : '暂未登录'}}</view>
      <view class="profile-subtitle">{{isLoggedIn ? '已登录，可以继续管理活动' : '登录后同步你的活动空间'}}</view>
      <view wx:if="{{isLoggedIn}}" class="status-tag">状态：{{user.status || 'ACTIVE'}}</view>
    </view>
  </view>

  <view class="section card menu-card">
    <view wx:if="{{isLoggedIn}}" class="menu-item" bindtap="goActivities">
      <view>
        <view class="menu-title">我的活动</view>
        <view class="menu-desc">查看我创建和加入的活动</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
    <view wx:else class="menu-item" bindtap="goLogin">
      <view>
        <view class="menu-title">登录玩伴空间</view>
        <view class="menu-desc">创建活动，或加入朋友分享的活动</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="showAbout">
      <view>
        <view class="menu-title">关于玩伴空间</view>
        <view class="menu-desc">朋友聚会和旅行活动协作工具</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
  </view>

  <view class="section action-area">
    <t-button wx:if="{{isLoggedIn}}" variant="outline" block bind:tap="loadCurrentUser" loading="{{loading}}">刷新用户信息</t-button>
    <t-button wx:if="{{isLoggedIn}}" variant="text" block bind:tap="clearLogin">退出登录</t-button>
    <t-button wx:else theme="primary" block bind:tap="goLogin">去登录</t-button>
  </view>
</view>
