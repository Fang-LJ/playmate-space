<view class="page">
  <view class="page-title">我的</view>
  <view class="page-subtitle">{{isLoggedIn ? '已连接后端当前用户接口' : '登录后可查看个人信息和活动协作状态'}}</view>

  <view class="section card profile-card">
    <image wx:if="{{isLoggedIn && user.avatarUrl}}" class="avatar-image" src="{{user.avatarUrl}}" mode="aspectFill" />
    <view wx:else class="avatar-placeholder">{{isLoggedIn ? '玩' : '未'}}</view>
    <view class="profile-info">
      <view class="profile-name">{{isLoggedIn ? user.nickname : '暂未登录'}}</view>
      <view class="muted">{{isLoggedIn ? '用户状态：' + user.status : '点击下方入口完成登录'}}</view>
      <view wx:if="{{isLoggedIn && user.lastLoginTime}}" class="last-login">最近登录：{{user.lastLoginTime}}</view>
    </view>
  </view>

  <view class="section card">
    <t-cell wx:if="{{isLoggedIn}}" title="当前用户接口" note="GET /api/users/me 已接入" />
    <t-cell wx:else title="登录玩伴空间" note="本地开发使用 mockOpenid" arrow bind:click="goLogin" />
    <view class="button-row">
      <t-button wx:if="{{isLoggedIn}}" variant="outline" block bind:tap="loadCurrentUser" loading="{{loading}}">刷新用户信息</t-button>
      <t-button wx:if="{{isLoggedIn}}" variant="text" block bind:tap="clearLogin">退出登录</t-button>
      <t-button wx:else theme="primary" block bind:tap="goLogin">去登录</t-button>
    </view>
  </view>

  <view class="section card">
    <view class="tool-title">未登录处理验证</view>
    <view class="muted">清理 token 后再次请求当前用户接口，后端返回 401 时会保持未登录状态。</view>
    <view class="button-row">
      <t-button variant="outline" block bind:tap="verifyUnauthorized">模拟无 token 请求 /api/users/me</t-button>
    </view>
  </view>
</view>
