.profile-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8fbf8 100%);
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 34rpx;
  background: var(--pm-primary-light);
  color: var(--pm-primary-dark);
  font-size: 42rpx;
  font-weight: 900;
}

.avatar-image {
  width: 112rpx;
  height: 112rpx;
  border-radius: 34rpx;
  background: var(--pm-primary-light);
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  color: var(--pm-text);
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.3;
}

.profile-subtitle {
  margin-top: 8rpx;
  color: var(--pm-text-muted);
  font-size: 25rpx;
  line-height: 1.45;
}

.status-tag {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: var(--pm-primary-light);
  color: var(--pm-primary-dark);
  font-size: 22rpx;
  font-weight: 700;
}

.menu-card {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx 32rpx;
}

.menu-item + .menu-item {
  border-top: 1rpx solid var(--pm-border);
}

.menu-title {
  color: var(--pm-text);
  font-size: 29rpx;
  font-weight: 800;
}

.menu-desc {
  margin-top: 8rpx;
  color: var(--pm-text-muted);
  font-size: 24rpx;
}

.menu-arrow {
  color: #9aa7a0;
  font-size: 42rpx;
  line-height: 1;
}

.action-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
