.mine-page {
  min-height: 100vh;
  padding: 0;
}

.mine-content {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  width: calc(100% - 80rpx);
  box-sizing: border-box;
  margin: 0 auto;
  padding-top: var(--mine-safe-top);
  padding-bottom: calc(310rpx + env(safe-area-inset-bottom));
}

.user-card {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  min-height: 264rpx;
  gap: 32rpx;
  padding: 40rpx 30rpx;
  border: 1rpx solid #d7e5dc;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(13, 36, 26, 0.08);
}

.user-avatar {
  flex: 0 0 128rpx;
  width: 128rpx;
  height: 128rpx;
  border-radius: 44rpx;
  background: #ddf2e7;
}

.user-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #246b58;
  font-size: 54rpx;
  font-weight: 800;
}

.user-main {
  flex: 1;
  min-width: 0;
}

.user-name {
  color: #14211a;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 56rpx;
}

.user-desc {
  margin-top: 2rpx;
  color: #66756c;
  font-size: 26rpx;
  line-height: 38rpx;
}

.function-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  min-height: 140rpx;
  padding: 24rpx 30rpx;
  border: 1rpx solid #d7e5dc;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(13, 36, 26, 0.08);
}

.reminder-card {
  min-height: 140rpx;
}

.action-title {
  color: #14211a;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 46rpx;
}

.action-desc {
  margin-top: 2rpx;
  color: #66756c;
  font-size: 24rpx;
  line-height: 34rpx;
}

.action-arrow {
  flex: 0 0 auto;
  color: #97a49c;
  font-size: 52rpx;
  line-height: 1;
}

.mine-bottom-action {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  /* Keep the action above the custom tab bar instead of underneath it. */
  bottom: calc(128rpx + env(safe-area-inset-bottom));
  width: auto;
  box-sizing: border-box;
  z-index: 20;
}

.bottom-action-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 100%;
  margin: 0;
  padding-right: 0;
  padding-left: 0;
  height: 96rpx;
  min-height: 96rpx;
  border-radius: 26rpx;
  font-size: 32rpx;
  line-height: 96rpx;
  box-sizing: border-box;
}

.mine-bottom-action .secondary {
  border-color: #56aa82;
  color: #246b58;
}

.mine-bottom-action .primary {
  background: #56aa82;
  box-shadow: 0 12rpx 32rpx rgba(13, 36, 26, 0.08);
}
