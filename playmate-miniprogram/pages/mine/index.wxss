.mine-page {
  padding-left: 48rpx;
  padding-right: 48rpx;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 30rpx;
}

.user-avatar {
  flex: 0 0 104rpx;
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  background: var(--pm-primary-light);
}

.user-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--pm-primary-dark);
  font-size: 36rpx;
  font-weight: 800;
}

.user-main {
  flex: 1;
  min-width: 0;
}

.user-name {
  color: var(--pm-text);
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.3;
}

.user-desc,
.user-phone {
  margin-top: 8rpx;
  color: var(--pm-text-muted);
  font-size: 24rpx;
  line-height: 1.45;
}

.user-phone {
  opacity: 0.82;
}

.user-action {
  flex: 0 0 auto;
  color: var(--pm-primary-dark);
  font-size: 24rpx;
  font-weight: 700;
}

.mine-action-card,
.version-card,
.guest-card {
  padding: 30rpx;
}

.mine-action-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.action-title {
  color: var(--pm-text);
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.35;
}

.action-desc {
  margin-top: 10rpx;
  color: var(--pm-text-muted);
  font-size: 25rpx;
  line-height: 1.45;
}

.action-arrow {
  color: #a4afa8;
  font-size: 40rpx;
  line-height: 1;
}

.logout-area {
  margin-top: 48rpx;
}

.logout-button {
  color: var(--pm-text-muted);
}

.login-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
