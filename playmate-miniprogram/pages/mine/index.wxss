.profile-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  border-radius: 32rpx;
  background: #e9f5ef;
  color: #2f6f5e;
  font-size: 40rpx;
  font-weight: 700;
}

.avatar-image {
  width: 104rpx;
  height: 104rpx;
  border-radius: 32rpx;
  background: #e9f5ef;
}

.profile-info {
  flex: 1;
}

.profile-name {
  margin-bottom: 8rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.button-row {
  margin-top: 24rpx;
}

.button-row t-button + t-button {
  margin-top: 16rpx;
}

.last-login {
  margin-top: 8rpx;
  color: #6f7c75;
  font-size: 24rpx;
}

.tool-title {
  margin-bottom: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.upload-result {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f6f8f5;
  color: #1f2a24;
  font-size: 24rpx;
  line-height: 1.7;
  word-break: break-all;
}

.upload-url {
  color: #6f7c75;
}

.upload-preview {
  display: block;
  width: 180rpx;
  height: 180rpx;
  margin-top: 18rpx;
  border-radius: 18rpx;
  background: #e9f5ef;
}
