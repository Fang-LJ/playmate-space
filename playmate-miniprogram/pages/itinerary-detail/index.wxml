<view class="page">
  <view wx:if="{{loading}}" class="section card">正在加载行程…</view>
  <view wx:elif="{{errorMessage}}" class="section card">{{errorMessage}}</view>
  <view wx:else>
    <view class="page-title">行程详情</view>
    <view class="section pm-hero-card"><view class="section-title">{{detail.itinerary.title}}</view><view class="section-desc">{{detail.itinerary.itineraryDate}} · {{detail.itinerary.timeText}}</view><view class="section-desc">{{detail.itinerary.locationName || '地点待定'}} {{detail.itinerary.address || ''}}</view><view class="pm-status">{{detail.itinerary.planningStatusText}}</view></view>
    <view class="section card"><view class="section-title">行程说明</view><view class="section-desc">{{detail.itinerary.description || '暂无备注'}}</view></view>
    <view class="section"><view class="section-title">关联投票</view><view wx:if="{{!detail.relatedPolls.length}}" class="card section-desc">还没有关联投票</view><view wx:for="{{detail.relatedPolls}}" wx:key="pollId" class="card poll-row" data-id="{{item.pollId}}" bindtap="goPoll"><view>{{item.title}}</view><view class="muted">{{item.statusText}} · {{item.resultText}}</view></view></view>
    <view class="p1-bottom"><button class="pm-native-button primary" bindtap="newPoll">发起投票</button><button class="pm-native-button secondary" bindtap="edit">编辑行程</button></view>
    <button class="pm-native-button danger-ghost" bindtap="cancel">取消行程</button>
  </view>
</view>
