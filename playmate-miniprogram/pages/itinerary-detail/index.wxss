.itinerary-detail-page { padding-bottom: 72rpx; }
.itinerary-hero { position: relative; }
.itinerary-type { margin-bottom: 12rpx; color: var(--pm-primary-dark); font-size: 22rpx; font-weight: 800; }
.itinerary-summary { margin-top: 18rpx; color: var(--pm-text); font-size: 27rpx; font-weight: 700; }
.detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22rpx 18rpx; }
.detail-heading { grid-column: 1 / -1; font-size: 29rpx; font-weight: 800; }
.detail-cell { display: flex; flex-direction: column; gap: 8rpx; min-width: 0; }
.detail-cell.full { grid-column: 1 / -1; }
.detail-cell text { color: var(--pm-text-muted); font-size: 22rpx; }
.detail-value { overflow-wrap: anywhere; color: var(--pm-text); font-size: 26rpx; font-weight: 700; }
.poll-row { margin-top: 14rpx; display: flex; align-items: center; justify-content: space-between; gap: 16rpx; font-size: 27rpx; }
.poll-main { flex: 1; min-width: 0; }
.poll-arrow { color: var(--pm-text-muted); font-size: 36rpx; }
.applied-summary { margin-top: 10rpx; color: var(--pm-primary-dark); font-size: 22rpx; line-height: 1.45; }
.pm-status { margin-top: 20rpx; }
.itinerary-action-anchor { position: absolute; top: 24rpx; right: 24rpx; z-index: 12; }
.itinerary-action-trigger { display: flex; align-items: center; justify-content: center; width: 58rpx; height: 58rpx; color: var(--pm-primary-dark); font-size: 29rpx; font-weight: 900; letter-spacing: 2rpx; }
.itinerary-action-menu { position: absolute; top: 70rpx; right: 0; width: 190rpx; padding: 8rpx; border: 1rpx solid var(--pm-border); border-radius: 18rpx; background: #fff; box-shadow: 0 18rpx 36rpx rgba(47, 111, 94, 0.16); }
.itinerary-action-item { display: flex; align-items: center; gap: 12rpx; min-height: 58rpx; padding: 0 12rpx; border-radius: 12rpx; color: var(--pm-text); font-size: 24rpx; font-weight: 700; }
.itinerary-action-item:active { background: var(--pm-primary-light); }
.itinerary-action-item.warning { color: #9a7000; }
.itinerary-action-item.danger { color: var(--pm-danger); }
.itinerary-action-item.danger:active { background: var(--pm-danger-soft); }
.itinerary-action-icon { display: inline-flex; align-items: center; justify-content: center; width: 30rpx; color: currentColor; font-size: 32rpx; line-height: 1; }
.itinerary-action-mask { position: fixed; z-index: 10; top: 0; right: 0; bottom: 0; left: 0; background: transparent; }
