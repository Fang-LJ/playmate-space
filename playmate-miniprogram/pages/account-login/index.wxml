<view class="page account-page">
  <view class="page-title">账号登录</view>
  <view class="page-subtitle">使用手机号或邮箱登录你的玩伴空间账号。</view>

  <view class="section card pm-form-card">
    <view class="pm-field">
      <view class="pm-label">手机号 / 邮箱</view>
      <input class="pm-input" maxlength="128" placeholder="请输入手机号或邮箱" value="{{form.account}}" data-field="account" bindinput="handleInput" />
    </view>
    <view class="pm-field">
      <view class="pm-label">密码</view>
      <input class="pm-input" password maxlength="64" placeholder="请输入密码" value="{{form.password}}" data-field="password" bindinput="handleInput" />
    </view>
  </view>

  <view class="section account-actions">
    <button class="pm-native-button primary" loading="{{loading}}" bindtap="submitLogin">{{loading ? '登录中...' : '登录'}}</button>
    <button class="pm-native-button secondary" loading="{{wxLoading}}" bindtap="handleWxLogin">{{wxLoading ? '登录中...' : '微信授权登录'}}</button>
    <view class="minor-link" bindtap="goRegister">还没有账号？去注册</view>
  </view>
</view>
