.invalid-page {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.invalid-card {
  width: 100%;
  box-sizing: border-box;
  padding: 44rpx 34rpx;
  border: 1rpx solid #e1e8e3;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 42rpx rgba(47, 111, 94, 0.08);
  text-align: center;
}

.invalid-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #e9f5ef;
  color: #2f6f5e;
  font-size: 52rpx;
  font-weight: 800;
}

.invalid-title {
  margin-top: 28rpx;
  color: #1f2a24;
  font-size: 36rpx;
  font-weight: 700;
}

.invalid-desc {
  margin: 16rpx 0 34rpx;
  color: #6f7c75;
  font-size: 28rpx;
  line-height: 1.5;
}
