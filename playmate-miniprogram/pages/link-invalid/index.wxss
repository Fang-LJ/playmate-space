.invalid-page {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.invalid-card {
  width: 100%;
  box-sizing: border-box;
  padding: 50rpx 36rpx;
  border: 1rpx solid var(--pm-border);
  border-radius: 34rpx;
  background: var(--pm-card);
  box-shadow: var(--pm-shadow-card);
  text-align: center;
}

.invalid-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--pm-primary-light);
  color: var(--pm-primary-dark);
  font-size: 52rpx;
  font-weight: 800;
}

.invalid-title {
  margin-top: 28rpx;
  color: var(--pm-text);
  font-size: 36rpx;
  font-weight: 700;
}

.invalid-desc {
  margin: 16rpx 0 34rpx;
  color: var(--pm-text-muted);
  font-size: 28rpx;
  line-height: 1.5;
}
