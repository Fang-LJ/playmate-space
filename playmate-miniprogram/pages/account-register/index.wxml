<view class="page account-page">
  <view class="page-title">注册账号</view>
  <view class="page-subtitle">创建玩伴空间账号，之后可以用手机号或邮箱继续登录。</view>

  <view class="section card pm-form-card">
    <view class="pm-field">
      <view class="pm-label">昵称</view>
      <input class="pm-input" maxlength="64" placeholder="可选，默认玩伴用户" value="{{form.nickname}}" data-field="nickname" bindinput="handleInput" />
    </view>
    <view class="pm-field">
      <view class="pm-label">手机号 / 邮箱</view>
      <input class="pm-input" maxlength="128" placeholder="请输入手机号或邮箱" value="{{form.account}}" data-field="account" bindinput="handleInput" />
    </view>
    <view class="pm-field">
      <view class="pm-label">密码</view>
      <input class="pm-input" password maxlength="64" placeholder="6-64 位密码" value="{{form.password}}" data-field="password" bindinput="handleInput" />
    </view>
    <view class="pm-field">
      <view class="pm-label">确认密码</view>
      <input class="pm-input" password maxlength="64" placeholder="请再次输入密码" value="{{form.confirmPassword}}" data-field="confirmPassword" bindinput="handleInput" />
    </view>
  </view>

  <view class="section account-actions">
    <button class="pm-native-button primary" loading="{{loading}}" bindtap="submitRegister">{{loading ? '注册中...' : '注册并登录'}}</button>
    <view class="minor-link" bindtap="goLogin">已有账号？去登录</view>
  </view>
</view>
