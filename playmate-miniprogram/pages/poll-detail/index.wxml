<view class="page">
  <view wx:if="{{loading}}" class="section card">正在加载投票…</view>
  <view wx:elif="{{errorMessage}}" class="section card">{{errorMessage}}</view>
  <view wx:else>
    <view class="page-title">投票详情</view>
    <view class="section pm-hero-card">
      <view class="poll-state-row"><view class="pm-status">{{poll.statusText}}</view><view class="poll-purpose">{{poll.purposeText}}</view></view>
      <view class="section-title">{{poll.title}}</view>
      <view wx:if="{{poll.description}}" class="section-desc">{{poll.description}}</view>
      <view class="section-desc">决定{{poll.decisionText}} · {{poll.voteType === 'SINGLE' ? '单选' : '多选'}}</view>
      <view class="section-desc">截止时间：{{poll.deadlineText}}</view>
      <view wx:if="{{poll.targetItineraryTitle}}" class="poll-context">关联行程：{{poll.targetItineraryTitle}}</view>
    </view>

    <view class="section">
      <view class="section-title">投票选项</view>
      <view wx:for="{{poll.options}}" wx:key="optionId" class="option-card {{item.selected ? 'selected' : ''}}" data-id="{{item.optionId}}" bindtap="select">
        <view class="choice-control {{poll.voteType === 'SINGLE' ? 'radio' : 'checkbox'}} {{item.selected ? 'checked' : ''}}"><view wx:if="{{item.selected && poll.voteType === 'SINGLE'}}" class="radio-dot"></view><view wx:if="{{item.selected && poll.voteType !== 'SINGLE'}}" class="check-mark">✓</view></view>
        <view class="option-content"><view class="option-name">{{item.optionText}}</view><view wx:if="{{item.hasDescription}}" class="option-desc">{{item.optionDescription}}</view></view>
        <view class="vote-count">{{item.voteText}}</view>
      </view>
    </view>

    <view wx:if="{{poll.status === 'ACTIVE'}}" class="p1-bottom">
      <button class="pm-native-button primary" loading="{{submitting}}" bindtap="vote">{{poll.currentUserOptionIds.length ? '修改投票' : '提交投票'}}</button>
      <button wx:if="{{canManage}}" class="pm-native-button secondary" bindtap="close">结束投票</button>
    </view>

    <view wx:if="{{poll.status === 'CLOSED'}}" class="section card result-card">
      <view class="section-title">投票结果</view>
      <view class="section-desc">{{poll.resultApplyText}}</view>
      <button wx:if="{{poll.resultApplyStatus === 'REVIEW_REQUIRED' && poll.winnerOptionId && canApply}}" class="pm-native-button primary" data-id="{{poll.winnerOptionId}}" bindtap="apply">确认应用结果</button>
      <button wx:if="{{poll.generatedItineraryId || poll.targetItineraryId}}" class="pm-native-button secondary" bindtap="goItinerary">查看行程</button>
    </view>
  </view>
</view>
