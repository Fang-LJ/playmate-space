<view class="page"><view wx:if="{{loading}}" class="section card">正在加载…</view><view wx:elif="{{errorMessage}}" class="section card">{{errorMessage}}</view><view wx:else><view class="page-title">投票详情</view><view class="section pm-hero-card"><view class="section-title">{{poll.title}}</view><view class="section-desc">{{poll.decisionType}} · {{poll.voteType==='SINGLE'?'单选':'多选'}} · {{poll.deadline||'未设置截止时间'}}</view><view wx:if="{{poll.targetItineraryTitle}}" class="section-desc">关联行程：{{poll.targetItineraryTitle}}</view></view><view class="section"><view class="section-title">选项</view><view wx:for="{{poll.options}}" wx:key="optionId" class="option-card {{selected.indexOf(item.optionId)!==-1?'selected':''}}" data-id="{{item.optionId}}" bindtap="select"><view><view class="option-name">{{item.optionText}}</view><view class="option-desc">{{item.optionDescription}}</view></view><view class="vote-count">{{item.voteCount}} 票</view></view></view><view wx:if="{{poll.status==='ACTIVE'}}" class="p1-bottom"><button class="pm-native-button primary" loading="{{submitting}}" bindtap="vote">{{poll.currentUserOptionIds.length?'修改投票':'提交投票'}}</button><button class="pm-native-button secondary" bindtap="close">结束投票</button></view><view wx:if="{{poll.status==='CLOSED'}}" class="section card"><view class="section-title">投票结果</view><view class="section-desc">应用状态：{{poll.resultApplyStatus}}</view><button wx:if="{{poll.resultApplyStatus==='REVIEW_REQUIRED' && poll.winnerOptionId}}" class="pm-native-button primary" data-id="{{poll.winnerOptionId}}" bindtap="apply">确认应用结果</button><button wx:if="{{poll.generatedItineraryId||poll.targetItineraryId}}" class="pm-native-button secondary" bindtap="goItinerary">查看行程</button></view></view></view>
