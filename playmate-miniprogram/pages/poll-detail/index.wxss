.option-card{display:flex;align-items:center;justify-content:space-between;margin-top:16rpx;padding:26rpx;border:1rpx solid var(--pm-border);border-radius:28rpx;background:#fff;box-shadow:var(--pm-shadow-soft)}.option-card.selected{border-color:var(--pm-primary);background:var(--pm-primary-light)}.option-name{font-size:28rpx;font-weight:800}.option-desc{margin-top:8rpx;color:var(--pm-text-muted);font-size:23rpx}.vote-count{color:var(--pm-primary-dark);font-size:27rpx;font-weight:800}.p1-bottom{display:flex;gap:16rpx;margin-top:30rpx}.p1-bottom button{flex:1}.section .pm-native-button{margin-top:20rpx}
