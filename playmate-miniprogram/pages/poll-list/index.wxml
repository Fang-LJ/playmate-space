<view class="page"><view class="page-title">投票</view><view class="page-subtitle">围绕吃什么、住哪里、去哪玩快速做决定。</view><view class="filter-row"><view wx:for="{{filters}}" wx:key="*this" class="pm-chip {{filter===item?'active':''}}" data-value="{{item}}" bindtap="choose">{{item==='ALL'?'全部':item==='ACTIVE'?'进行中':'已结束'}}</view></view><view wx:if="{{loading}}" class="section card">正在加载投票…</view><view wx:elif="{{errorMessage}}" class="section card">{{errorMessage}}</view><view wx:elif="{{!polls.length}}" class="section card empty-card"><view class="section-title">暂无投票</view><view class="section-desc">可以创建“吃什么、住哪里、去哪玩”等投票。</view><button wx:if="{{!readOnly}}" class="pm-native-button primary" bindtap="goCreate">创建投票</button></view><view wx:else><view wx:if="{{!visiblePolls.length}}" class="section card empty-card">当前筛选下没有投票。</view><view wx:for="{{visiblePolls}}" wx:key="pollId" class="section card poll-card" data-id="{{item.pollId}}" bindtap="goDetail"><view class="section-title">{{item.title}}</view><view class="section-desc">决定{{item.decisionText}} · {{item.participantCount}} 人参与 · {{item.statusText}}</view><view wx:if="{{item.deadlineText}}" class="section-desc">截止：{{item.deadlineText}}</view><view wx:if="{{item.targetItineraryTitle}}" class="poll-link">关联行程：{{item.targetItineraryTitle}}</view><view wx:if="{{item.appliedChangeSummary}}" class="applied-summary">{{item.appliedChangeSummary}}</view><view wx:if="{{item.resultApplyStatus==='REVIEW_REQUIRED'}}" class="review">{{item.resultText}}</view></view><view wx:if="{{!readOnly}}" class="p1-bottom"><button class="pm-native-button primary" bindtap="goCreate">创建投票</button></view></view></view>
