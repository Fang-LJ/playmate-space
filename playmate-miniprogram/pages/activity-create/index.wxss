.type-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18rpx;
}

.type-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 62rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--pm-border);
  border-radius: 16rpx;
  background: rgba(246, 248, 245, 0.84);
  color: var(--pm-text-muted);
  font-size: 25rpx;
  font-weight: 700;
}

.type-chip.active {
  border-color: var(--pm-primary);
  background: var(--pm-primary-light);
  color: var(--pm-primary-dark);
}

.cover-card {
  position: relative;
  height: 180rpx;
  overflow: hidden;
  border-radius: 22rpx;
  background: var(--pm-primary-light);
}

.cover-preview,
.cover-placeholder {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  position: relative;
  box-sizing: border-box;
  padding: 30rpx;
  background: linear-gradient(135deg, #e9f5ef 0%, #f6f8f5 48%, #f4e7b4 100%);
}

.cover-placeholder::before {
  content: "";
  position: absolute;
  right: 44rpx;
  top: 34rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--pm-accent);
  opacity: 0.88;
}

.cover-title {
  color: var(--pm-text);
  font-size: 32rpx;
  font-weight: 800;
}

.cover-desc {
  margin-top: 10rpx;
  color: var(--pm-text-muted);
  font-size: 25rpx;
}

.cover-action {
  position: absolute;
  right: 22rpx;
  bottom: 22rpx;
  padding: 10rpx 20rpx;
  border: 1rpx solid rgba(107, 175, 146, 0.28);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: var(--pm-primary-dark);
  font-size: 24rpx;
  font-weight: 700;
}

.date-row {
  display: flex;
  gap: 20rpx;
}

.half {
  flex: 1;
}

.date-box {
  box-sizing: border-box;
  min-height: 116rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid var(--pm-border);
}

.date-label {
  color: var(--pm-text-muted);
  font-size: 24rpx;
}

.date-value {
  margin-top: 10rpx;
  color: var(--pm-text);
  font-size: 31rpx;
  font-weight: 800;
}
