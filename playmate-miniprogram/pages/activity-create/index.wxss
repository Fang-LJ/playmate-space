.cover-card {
  position: relative;
  height: 300rpx;
  padding: 0;
  overflow: hidden;
}

.cover-preview,
.cover-placeholder {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  box-sizing: border-box;
  padding: 36rpx;
  background: linear-gradient(135deg, #e9f5ef 0%, #f6f8f5 45%, #f4e7b4 100%);
}

.cover-title {
  color: #1f2a24;
  font-size: 34rpx;
  font-weight: 700;
}

.cover-desc {
  margin-top: 12rpx;
  color: #6f7c75;
  font-size: 26rpx;
}

.cover-action {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #2f6f5e;
  font-size: 24rpx;
  font-weight: 600;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.label {
  color: #1f2a24;
  font-size: 26rpx;
  font-weight: 600;
}

.input,
.picker-value,
.textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 88rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #f6f8f5;
  border: 1rpx solid #e1e8e3;
  color: #1f2a24;
  font-size: 28rpx;
}

.textarea {
  height: 180rpx;
  line-height: 1.5;
}

.date-row {
  display: flex;
  gap: 20rpx;
}

.half {
  flex: 1;
}

.bottom-bar {
  display: flex;
  gap: 20rpx;
  padding: 28rpx 0 calc(28rpx + env(safe-area-inset-bottom));
}

.secondary-action {
  width: 180rpx;
}

.primary-action {
  flex: 1;
}
