.my-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8fbf8 100%);
}

.card-desc {
  margin-top: 8rpx;
  color: var(--pm-text-muted);
  font-size: 26rpx;
}

.edit-nickname {
  flex: 0 0 auto;
  min-width: 96rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: var(--pm-primary);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.member-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-sizing: border-box;
  padding: 24rpx;
  border: 1rpx solid var(--pm-border);
  border-radius: 26rpx;
  background: var(--pm-card);
  box-shadow: 0 10rpx 30rpx rgba(47, 111, 94, 0.05);
}

.avatar {
  flex: 0 0 88rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--pm-primary-light);
  color: var(--pm-primary-dark);
  font-size: 34rpx;
  font-weight: 700;
}

.member-main {
  flex: 1;
  min-width: 0;
}

.member-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.member-name {
  color: var(--pm-text);
  font-size: 30rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-meta {
  margin-top: 8rpx;
  color: var(--pm-text-muted);
  font-size: 24rpx;
}

.tag {
  flex: 0 0 auto;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.mine-tag {
  color: var(--pm-primary-dark);
  background: var(--pm-primary-light);
}

.creator-tag {
  color: #8a6500;
  background: var(--pm-accent-soft);
}

.remove-button {
  flex: 0 0 auto;
  min-width: 86rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 0 18rpx;
  border: 1rpx solid rgba(217, 76, 76, 0.32);
  border-radius: 999rpx;
  background: var(--pm-danger-soft);
  color: var(--pm-danger);
  font-size: 23rpx;
  font-weight: 700;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
}

.empty-desc {
  color: var(--pm-text-muted);
  font-size: 28rpx;
  line-height: 1.5;
}
