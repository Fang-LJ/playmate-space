<view class="page">
  <view class="page-title">成员</view>
  <view class="page-subtitle">查看当前活动成员，修改自己的活动内昵称。</view>

  <view wx:if="{{loading}}" class="section card stack">
    <view class="empty-title">正在加载成员</view>
    <view class="empty-desc">正在读取活动成员列表。</view>
  </view>

  <view wx:elif="{{errorMessage}}" class="section card stack">
    <view class="empty-title">无法查看成员</view>
    <view class="empty-desc">{{errorMessage}}</view>
    <t-button theme="primary" block bind:tap="retryLoad">重新加载</t-button>
    <t-button variant="outline" block bind:tap="goActivityList">返回活动列表</t-button>
  </view>

  <block wx:else>
    <view class="section card my-card">
      <view>
        <view class="section-title">我的活动昵称</view>
        <view class="card-desc">{{myMember.nickname || '玩伴用户'}}</view>
      </view>
      <view class="edit-nickname" bindtap="goEditNickname">修改</view>
    </view>

    <view wx:if="{{members.length === 0}}" class="section card stack">
      <view class="empty-title">暂无成员</view>
      <view class="empty-desc">当前活动还没有可展示的成员。</view>
    </view>

    <view wx:else class="section member-list">
      <view wx:for="{{members}}" wx:key="memberId" class="member-card">
        <image wx:if="{{item.avatarUrl}}" class="avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar avatar-placeholder">{{item.avatarText}}</view>

        <view class="member-main">
          <view class="member-name-row">
            <view class="member-name">{{item.nickname}}</view>
            <view wx:if="{{item.isCurrentUser}}" class="tag mine-tag">我</view>
            <view wx:if="{{item.role === 'CREATOR'}}" class="tag creator-tag">创建者</view>
          </view>
          <view class="member-meta">{{item.roleText}} · {{item.joinedText}}</view>
        </view>

        <view
          wx:if="{{item.canRemove}}"
          class="remove-button"
          data-member-id="{{item.memberId}}"
          data-nickname="{{item.nickname}}"
          bind:tap="confirmRemove"
        >
          {{removingMemberId === item.memberId ? '移除中' : '移除'}}
        </view>
      </view>
    </view>
  </block>
</view>
