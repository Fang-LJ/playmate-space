<view class="page">
  <view class="hero">
    <view class="hero-main">
      <view class="hero-question">想要去哪玩？</view>
      <view class="home-actions">
        <view class="todo-action" bindtap="goTodos" aria-label="我的待办">
          <view class="todo-bell"><view class="todo-bell-dot"></view></view>
          <view wx:if="{{todoCount > 0}}" class="todo-badge">{{todoCount > 99 ? '99+' : todoCount}}</view>
        </view>
        <view class="home-action join-action" bindtap="openJoinDialog">加入</view>
        <view class="home-action create-action" bindtap="goCreate">创建</view>
      </view>
    </view>
    <view class="page-subtitle">把行程、成员和照片放进同一个活动空间。</view>
  </view>

  <view wx:if="{{loading}}" class="section card stack">
    <view class="empty-title">正在加载活动</view>
    <view class="empty-desc">稍等一下，正在同步你的活动空间。</view>
  </view>

  <view wx:elif="{{!isLoggedIn}}" class="section card stack">
    <view class="empty-title">先登录再创建活动</view>
    <view class="empty-desc">登录后可以创建活动、查看自己加入的活动。</view>
    <button class="pm-native-button primary" bindtap="goLogin">去登录</button>
  </view>

  <view wx:elif="{{errorMessage}}" class="section card stack">
    <view class="empty-title">加载失败</view>
    <view class="empty-desc">{{errorMessage}}</view>
    <button class="pm-native-button primary" bindtap="retryLoad">重新加载</button>
  </view>

  <view wx:elif="{{loaded && activities.length === 0}}" class="section card stack">
    <view class="empty-title">还没有活动</view>
    <view class="empty-desc">创建一个活动空间，和朋友一起规划行程、账本和照片。</view>
    <button class="pm-native-button primary" bindtap="goCreate">创建活动</button>
  </view>

  <view wx:else class="activity-list">
    <view class="filter-row">
      <view
        wx:for="{{filters}}"
        wx:key="value"
        class="pm-chip {{activeFilter === item.value ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="changeFilter"
      >
        {{item.label}}
      </view>
    </view>

    <view wx:if="{{displayActivities.length === 0}}" class="card stack">
      <view class="empty-title">这个状态下暂无活动</view>
      <view class="empty-desc">切换筛选条件，或创建一个新的活动空间。</view>
    </view>

    <view
      wx:for="{{displayActivities}}"
      wx:key="activityId"
      class="activity-card"
      data-id="{{item.activityId}}"
      bindtap="goDetail"
    >
      <image wx:if="{{item.coverUrl}}" class="activity-cover" src="{{item.coverUrl}}" mode="aspectFill" />
      <view wx:else class="activity-cover default-cover">
        <view class="cover-sun"></view>
        <view class="cover-line"></view>
        <view class="cover-line short"></view>
      </view>
      <view class="activity-info">
        <view class="activity-top">
          <view class="activity-name">{{item.name}}</view>
          <view class="pm-status {{item.statusClass}}">{{item.statusText}}</view>
        </view>
        <view class="activity-meta">{{item.typeText}} · {{item.locationText}}</view>
        <view class="activity-date">{{item.dateText}}</view>
        <view class="activity-footer">
          <view class="member-pill">{{item.memberCount}} 位成员</view>
          <view class="role-pill">{{item.roleText}}</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showJoinDialog}}" class="join-dialog-mask" catchtap="closeJoinDialog">
    <view class="join-dialog" catchtap="stopPropagation">
      <view class="join-dialog-title">加入活动</view>
      <input class="pm-input join-dialog-input" maxlength="64" placeholder="请输入活动分享码" value="{{shareCode}}" bindinput="handleShareCodeInput" />
      <view class="join-dialog-hint">好友发送的活动分享码可在活动邀请中查看</view>
      <view wx:if="{{joinError}}" class="join-dialog-error">{{joinError}}</view>
      <view class="join-dialog-actions">
        <button class="pm-native-button secondary dialog-button" bindtap="closeJoinDialog">取消</button>
        <button class="pm-native-button primary dialog-button" bindtap="viewInvite">查看活动</button>
      </view>
    </view>
  </view>
</view>
