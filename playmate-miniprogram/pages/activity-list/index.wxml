<view class="page">
  <view class="page-title">我的活动</view>
  <view class="page-subtitle">这里后续展示我创建或加入的活动。</view>

  <view class="section card stack">
    <view class="empty-title">还没有活动</view>
    <view class="empty-desc">P0 后续会接入活动列表、创建活动和活动详情。</view>
    <t-button theme="primary" block bind:tap="handleCreateTodo">创建活动</t-button>
  </view>

  <view class="section card stack">
    <view class="tool-title">基础联调</view>
    <view class="muted">用于验证 request 工具是否能访问后端健康检查接口。</view>
    <t-button variant="outline" block bind:tap="handleHealthCheck">检查后端 /api/health</t-button>
    <view wx:if="{{healthMessage}}" class="health-result">{{healthMessage}}</view>
  </view>

  <view class="section">
    <t-tag theme="success" variant="light">P0-008 / P0-009 / P0-010 基础骨架</t-tag>
  </view>
</view>
