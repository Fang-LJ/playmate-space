.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-question {
  margin-top: 22rpx;
  color: var(--pm-text);
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.25;
}

.create-button {
  flex: 0 0 auto;
  min-width: 132rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin-top: 6rpx;
  border-radius: 18rpx;
  background: var(--pm-primary);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 26rpx rgba(107, 175, 146, 0.22);
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
}

.empty-desc {
  color: #6f7c75;
  font-size: 28rpx;
  line-height: 1.5;
}

.activity-list {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 2rpx;
}

.activity-card {
  display: flex;
  gap: 24rpx;
  padding: 26rpx;
  background: var(--pm-card);
  border: 1rpx solid var(--pm-border);
  border-radius: var(--pm-radius-card);
  box-shadow: var(--pm-shadow-card);
}

.activity-cover {
  width: 176rpx;
  height: 176rpx;
  flex: 0 0 176rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: var(--pm-primary-light);
}

.default-cover {
  position: relative;
  box-sizing: border-box;
  padding: 26rpx;
  background: linear-gradient(145deg, #e9f5ef 0%, #f4e7b4 100%);
}

.cover-sun {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: var(--pm-accent);
}

.cover-line {
  margin-top: 38rpx;
  width: 100rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
}

.cover-line.short {
  margin-top: 14rpx;
  width: 72rpx;
  background: rgba(107, 175, 146, 0.28);
}

.activity-info {
  min-width: 0;
  flex: 1;
}

.activity-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.activity-name {
  flex: 1;
  color: var(--pm-text);
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.activity-meta {
  margin-top: 10rpx;
  color: var(--pm-text-muted);
  font-size: 26rpx;
  line-height: 1.45;
}

.activity-date {
  margin-top: 8rpx;
  color: var(--pm-text-muted);
  font-size: 25rpx;
  line-height: 1.45;
}

.activity-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 18rpx;
  color: var(--pm-primary);
  font-size: 24rpx;
  font-weight: 700;
}
