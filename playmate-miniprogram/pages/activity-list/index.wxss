.hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.hero-question {
  flex: 1;
  min-width: 0;
  color: var(--pm-text);
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.25;
  white-space: nowrap;
}

.home-actions {
  display: flex;
  align-items: center;
  flex: 0 0 auto;
  gap: 10rpx;
}

.todo-action,
.home-action {
  position: relative;
  flex: 0 0 auto;
  height: 58rpx;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 18rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.todo-action {
  display: flex;
  align-items: center;
  width: 58rpx;
  border: 1rpx solid var(--pm-border);
  background: rgba(255, 255, 255, 0.88);
}

.todo-bell {
  position: relative;
  width: 24rpx;
  height: 25rpx;
  border: 4rpx solid var(--pm-primary-dark);
  border-top-left-radius: 14rpx;
  border-top-right-radius: 14rpx;
  border-bottom: 0;
}

.todo-bell::before {
  content: '';
  position: absolute;
  left: -7rpx;
  right: -7rpx;
  bottom: -6rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: var(--pm-primary-dark);
}

.todo-bell-dot {
  position: absolute;
  left: 7rpx;
  bottom: -12rpx;
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: var(--pm-primary-dark);
}

.todo-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 5rpx;
  box-sizing: border-box;
  border: 3rpx solid var(--pm-bg);
  border-radius: 999rpx;
  background: #dc4f4f;
  color: #fff;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 1;
}

.home-action {
  display: flex;
  align-items: center;
  min-width: 74rpx;
  padding: 0 16rpx;
}

.join-action {
  border: 1rpx solid rgba(107, 175, 146, 0.46);
  background: rgba(255, 255, 255, 0.88);
  color: var(--pm-primary-dark);
}

.create-action {
  background: var(--pm-primary);
  color: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(107, 175, 146, 0.2);
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
}

.empty-desc {
  color: #6f7c75;
  font-size: 28rpx;
  line-height: 1.5;
}

.activity-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 2rpx;
}

.activity-card {
  display: flex;
  gap: 24rpx;
  padding: 26rpx;
  background: var(--pm-card);
  border: 1rpx solid var(--pm-border);
  border-radius: var(--pm-radius-card);
  box-shadow: var(--pm-shadow-card);
  transition: transform 0.15s ease;
}

.activity-cover {
  width: 176rpx;
  height: 176rpx;
  flex: 0 0 176rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: var(--pm-primary-light);
}

.default-cover {
  position: relative;
  box-sizing: border-box;
  padding: 26rpx;
  background: linear-gradient(145deg, #e9f5ef 0%, #f4e7b4 100%);
}

.cover-sun {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: var(--pm-accent);
}

.cover-line {
  margin-top: 38rpx;
  width: 100rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
}

.cover-line.short {
  margin-top: 14rpx;
  width: 72rpx;
  background: rgba(107, 175, 146, 0.28);
}

.activity-info {
  min-width: 0;
  flex: 1;
}

.activity-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.activity-name {
  flex: 1;
  color: var(--pm-text);
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.activity-meta {
  margin-top: 10rpx;
  color: var(--pm-text-muted);
  font-size: 26rpx;
  line-height: 1.45;
}

.activity-date {
  margin-top: 8rpx;
  color: var(--pm-text-muted);
  font-size: 25rpx;
  line-height: 1.45;
}

.activity-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 18rpx;
}

.member-pill,
.role-pill {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  box-sizing: border-box;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.member-pill {
  background: var(--pm-primary-light);
  color: var(--pm-primary-dark);
}

.role-pill {
  background: var(--pm-warning-soft);
  color: #8a6500;
}

.join-dialog-mask {
  position: fixed;
  z-index: 100;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  background: rgba(31, 42, 36, 0.38);
}

.join-dialog {
  width: 100%;
  box-sizing: border-box;
  padding: 36rpx 32rpx;
  border-radius: 30rpx;
  background: #fff;
  box-shadow: 0 24rpx 56rpx rgba(18, 39, 28, 0.2);
}

.join-dialog-title {
  color: var(--pm-text);
  font-size: 36rpx;
  font-weight: 800;
}

.join-dialog-input {
  margin-top: 26rpx;
}

.join-dialog-hint,
.join-dialog-error {
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.45;
}

.join-dialog-hint { color: var(--pm-text-muted); }
.join-dialog-error { color: var(--pm-danger); }

.join-dialog-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 30rpx;
}

.dialog-button {
  flex: 1;
  min-width: 0;
  margin: 0;
  font-size: 26rpx;
}
