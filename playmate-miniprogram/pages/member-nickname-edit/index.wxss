.form-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.label {
  color: #1f2a24;
  font-size: 28rpx;
  font-weight: 700;
}

.input {
  box-sizing: border-box;
  width: 100%;
  height: 92rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e1e8e3;
  border-radius: 20rpx;
  background: #ffffff;
  color: #1f2a24;
  font-size: 28rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: flex;
  gap: 18rpx;
  box-sizing: border-box;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e1e8e3;
  background: rgba(255, 255, 255, 0.96);
}

.secondary-action {
  flex: 0 0 200rpx;
}

.primary-action {
  flex: 1;
}
