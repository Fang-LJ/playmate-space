.profile-page {
  padding-bottom: 150rpx;
}

.avatar-card {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.avatar-frame {
  flex: 0 0 148rpx;
  width: 148rpx;
  height: 148rpx;
  box-sizing: border-box;
  padding: 8rpx;
  border-radius: 46rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: var(--pm-shadow-soft);
}

.avatar-preview,
.avatar-placeholder {
  width: 132rpx;
  height: 132rpx;
  border-radius: 40rpx;
}

.avatar-preview {
  background: var(--pm-primary-light);
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--pm-primary-light);
  color: var(--pm-primary-dark);
  font-size: 44rpx;
  font-weight: 900;
}

.avatar-info {
  flex: 1;
  min-width: 0;
}

.avatar-action {
  display: inline-flex;
  height: 56rpx;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin-top: 18rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(107, 175, 146, 0.34);
  background: rgba(255, 255, 255, 0.86);
  color: var(--pm-primary-dark);
  font-size: 24rpx;
  font-weight: 800;
}

.field-hint {
  color: var(--pm-text-muted);
  font-size: 23rpx;
  line-height: 1.45;
}

.gender-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.gender-chip {
  min-width: 96rpx;
  box-sizing: border-box;
  padding: 16rpx 20rpx;
  border: 1rpx solid var(--pm-border);
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--pm-text-muted);
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}

.gender-chip.active {
  border-color: var(--pm-primary);
  background: var(--pm-primary-light);
  color: var(--pm-primary-dark);
}

.fixed-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  box-sizing: border-box;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--pm-border);
  background: rgba(255, 255, 255, 0.96);
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
}

.empty-desc {
  color: var(--pm-text-muted);
  font-size: 28rpx;
  line-height: 1.5;
}
