.wechat-profile-page {
  padding-left: 48rpx;
  padding-right: 48rpx;
}

.profile-card {
  display: flex;
  flex-direction: column;
  gap: 34rpx;
}

.avatar-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 144rpx;
  height: 144rpx;
  border-radius: 44rpx;
  background: var(--pm-primary-light);
}

.avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--pm-primary-dark);
  font-size: 46rpx;
  font-weight: 900;
}

.avatar-edit {
  margin-top: 14rpx;
  color: var(--pm-primary-dark);
  font-size: 24rpx;
  font-weight: 700;
}

.profile-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
