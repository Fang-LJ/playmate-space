.wechat-profile-page {
  padding-left: 48rpx;
  padding-right: 48rpx;
}

.profile-card {
  display: flex;
  flex-direction: column;
  gap: 34rpx;
}

.wechat-avatar-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: auto;
  padding: 0;
  background: transparent;
  line-height: normal;
}

.wechat-avatar-button::after {
  border: 0;
}

.avatar {
  width: 144rpx;
  height: 144rpx;
  border-radius: 44rpx;
  background: var(--pm-primary-light);
}

.avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--pm-primary-dark);
  font-size: 46rpx;
  font-weight: 900;
}

.avatar-edit {
  margin-top: 14rpx;
  color: var(--pm-primary-dark);
  font-size: 24rpx;
  font-weight: 700;
}

.album-avatar-entry {
  margin-top: -18rpx;
  color: var(--pm-text-muted);
  font-size: 23rpx;
  text-align: center;
}

.phone-section {
  padding-top: 28rpx;
  border-top: 1rpx solid var(--pm-border);
}

.phone-desc {
  margin-top: 10rpx;
  color: var(--pm-text-muted);
  font-size: 23rpx;
  line-height: 1.5;
}

.phone-current {
  margin-top: 16rpx;
  color: var(--pm-primary-dark);
  font-size: 25rpx;
  font-weight: 700;
}

.phone-button {
  margin-top: 20rpx;
}

.profile-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
