<view class="page"><view class="page-title">创建投票</view><view class="page-subtitle">邀请成员一起做出这次活动的选择。</view><view wx:if="{{target}}" class="section pm-hero-card"><view class="section-desc">关联行程</view><view class="section-title">{{target.title}}</view><view class="section-desc">{{target.itineraryDate}} {{target.startTime||'全天'}}</view></view><view class="section card pm-form-card"><view class="pm-field"><view class="pm-label">投票问题</view><input class="pm-input" value="{{form.title}}" data-k="title" bindinput="input" placeholder="例如：今晚吃什么？"/></view><view class="pm-field"><view class="pm-label">投票用途</view><picker range="{{purposes}}" bindchange="choose" data-k="purpose"><view class="pm-picker">{{form.purpose}}</view></picker></view><view class="pm-field"><view class="pm-label">决定内容</view><picker range="{{decisionTypes}}" bindchange="choose" data-k="decisionType"><view class="pm-picker">{{form.decisionType}}</view></picker></view><view wx:if="{{form.purpose==='CREATE_ITINERARY'}}" class="pm-field"><view class="pm-label">生成行程</view><input class="pm-input" value="{{template.title}}" data-k="title" bindinput="templateInput" placeholder="固定行程标题"/><picker mode="date" value="{{template.itineraryDate}}" data-k="itineraryDate" bindchange="templateInput"><view class="pm-picker">{{template.itineraryDate||'选择日期'}}</view></picker></view><view class="pm-field"><view class="pm-label">截止日期（可选）</view><picker mode="date" value="{{form.deadline}}" bindchange="deadlineChange"><view class="pm-picker">{{form.deadline||'暂不设置'}}</view></picker></view><view class="pm-label">投票选项</view><view wx:for="{{form.options}}" wx:key="index" class="pm-field"><input class="pm-input" value="{{item.optionText}}" data-i="{{index}}" bindinput="option" placeholder="候选方案"/><input wx:if="{{form.purpose!=='GENERAL'}}" class="pm-input" value="{{item.payloadLocation}}" data-i="{{index}}" bindinput="optionLocation" placeholder="胜出后使用的地点（可选）"/></view><view class="pm-link" bindtap="add">+ 新增选项</view></view><view class="pm-bottom-bar"><view class="pm-primary-action"><button class="pm-native-button primary" loading="{{saving}}" bindtap="save">创建投票</button></view></view></view>
