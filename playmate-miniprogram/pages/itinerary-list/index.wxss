.date-title{margin:32rpx 0 16rpx;color:var(--pm-text);font-size:30rpx;font-weight:800}.itinerary-card{display:flex;align-items:flex-start;gap:18rpx;margin-top:14rpx;padding:24rpx;border:1rpx solid var(--pm-border);border-radius:28rpx;background:#fff;box-shadow:var(--pm-shadow-soft)}.itinerary-time{width:132rpx;color:var(--pm-text-muted);font-size:23rpx}.itinerary-main{flex:1;min-width:0}.itinerary-name{font-size:29rpx;font-weight:800}.itinerary-meta{margin-top:8rpx;color:var(--pm-text-muted);font-size:23rpx}.itinerary-status{color:var(--pm-primary-dark);font-size:22rpx}.empty-card{margin-top:32rpx}.empty-card .pm-native-button{margin-top:28rpx}.read-only-note{margin-top:22rpx;color:var(--pm-text-muted);font-size:24rpx}.p1-bottom{position:sticky;bottom:0;margin-top:30rpx;padding:20rpx 0 calc(20rpx + env(safe-area-inset-bottom));background:var(--pm-bg)}
