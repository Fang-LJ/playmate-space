.hero-name{margin-top:18rpx;font-size:42rpx;font-weight:900}.share-btn{width:210rpx;margin-top:22rpx}.members{display:flex;align-items:center;justify-content:space-between}.todo-card{padding:26rpx;border:1rpx solid #f3e19a;border-radius:28rpx;background:#fff9e6;box-shadow:var(--pm-shadow-soft)}.todo-line{margin-top:12rpx;font-size:25rpx;color:var(--pm-text)}.tab-bar{display:grid;grid-template-columns:repeat(4,1fr);padding:8rpx;border:1rpx solid var(--pm-border);border-radius:24rpx;background:#fff}.tab{padding:16rpx 4rpx;border-radius:18rpx;text-align:center;color:var(--pm-primary-dark);font-size:23rpx;font-weight:700}.tab.active{background:var(--pm-primary);color:#fff}.section-head{display:flex;align-items:center;justify-content:space-between}.compact-row{display:flex;gap:18rpx;align-items:flex-start;margin-top:14rpx;padding:22rpx;font-size:25rpx}.row-main{flex:1}.row-main>view:first-child{font-weight:800}.review{color:#8a6500;font-size:23rpx}.empty-card{margin-top:16rpx}.action-row{display:grid;gap:14rpx}
