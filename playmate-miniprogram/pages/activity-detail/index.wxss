.activity-space-card {
  position: relative;
  overflow: hidden;
  min-height: 310rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(107, 175, 146, 0.28);
  border-radius: 30rpx;
  background: linear-gradient(135deg, #e9f5ef 0%, #f6f8f5 62%, #f4e7b4 100%);
  box-shadow: var(--pm-shadow-card);
}

.cover-layer {
  position: absolute;
  right: 0;
  top: 0;
  width: 240rpx;
  height: 180rpx;
  opacity: 0.42;
}

.space-cover {
  width: 100%;
  height: 100%;
}

.default-hero {
  background: radial-gradient(circle at 60% 35%, #f2b84b 0 22rpx, transparent 24rpx),
    linear-gradient(145deg, #e9f5ef 0%, #f6f8f5 52%, #f4e7b4 100%);
}

.space-content {
  position: relative;
  z-index: 1;
  padding: 34rpx;
}

.activity-name {
  margin-top: 18rpx;
  color: var(--pm-text);
  font-size: 43rpx;
  font-weight: 900;
  line-height: 1.22;
}

.activity-meta {
  margin-top: 10rpx;
  color: var(--pm-text-muted);
  font-size: 26rpx;
  line-height: 1.45;
}

.activity-desc {
  margin-top: 18rpx;
  max-width: 520rpx;
  color: var(--pm-text-muted);
  font-size: 26rpx;
  line-height: 1.55;
}

.share-row {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.share-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 168rpx;
  height: 62rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.share-button.primary {
  background: var(--pm-primary);
  color: #ffffff;
}

.share-button.secondary {
  margin: 0;
  border: 1rpx solid var(--pm-primary);
  background: rgba(255, 255, 255, 0.72);
  color: var(--pm-primary-dark);
  line-height: 62rpx;
}

.share-button.secondary::after {
  border: 0;
}

.section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.link-text {
  color: var(--pm-text-muted);
  font-size: 24rpx;
}

.member-card {
  padding: 24rpx;
}

.member-strip {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
}

.member-dot {
  width: 56rpx;
  height: 56rpx;
  margin-right: -8rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
}

.dot-1 {
  background: #f4e7b4;
}

.dot-2 {
  background: #dff1eb;
}

.dot-3 {
  background: #e5eee8;
}

.dot-4 {
  background: #f7ead8;
}

.member-count {
  margin-left: 28rpx;
  color: var(--pm-text-muted);
  font-size: 25rpx;
}

.summary-card {
  padding: 26rpx;
}

.summary-row {
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: 24rpx;
}

.summary-label {
  color: var(--pm-text-muted);
  font-size: 24rpx;
}

.summary-value {
  margin-top: 8rpx;
  color: var(--pm-text);
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.4;
}

.module-section {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.module-title {
  color: var(--pm-text);
  font-size: 30rpx;
  font-weight: 800;
}

.module-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
}

.module-card {
  min-height: 154rpx;
  box-sizing: border-box;
  padding: 22rpx 14rpx;
  border: 1rpx solid var(--pm-border);
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(47, 111, 94, 0.05);
  text-align: center;
}

.module-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  margin: 0 auto 12rpx;
  border-radius: 16rpx;
  color: var(--pm-primary-dark);
  font-size: 24rpx;
  font-weight: 800;
}

.module-icon.warm {
  background: #f7ead8;
  color: #b56738;
}

.module-icon.green {
  background: var(--pm-primary-light);
}

.module-icon.yellow {
  background: #fff1bd;
  color: #8a6500;
}

.module-icon.gray {
  background: #eef3ef;
  color: #5f6f66;
}

.module-name {
  color: var(--pm-text);
  font-size: 27rpx;
  font-weight: 800;
}

.module-desc {
  margin-top: 8rpx;
  color: var(--pm-text-muted);
  font-size: 22rpx;
}

.action-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.action-button {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 66rpx;
  border-radius: 16rpx;
  font-size: 25rpx;
  font-weight: 700;
}

.action-button.primary {
  background: var(--pm-primary);
  color: #ffffff;
}

.action-button.ghost {
  border: 1rpx solid var(--pm-border);
  background: #ffffff;
  color: var(--pm-text);
}

.action-button.danger {
  border: 1rpx solid rgba(217, 76, 76, 0.32);
  background: var(--pm-danger-soft);
  color: var(--pm-danger);
}

.canceled-note {
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: var(--pm-danger-soft);
  color: var(--pm-danger);
  font-size: 26rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
}

.empty-desc {
  color: var(--pm-text-muted);
  font-size: 28rpx;
  line-height: 1.5;
}
