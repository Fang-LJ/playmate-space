.activity-detail-page { padding-top: 18rpx; padding-bottom: 72rpx; }
.hero-section { margin-top: 12rpx; }
.activity-space-card {
  position: relative;
  overflow: hidden;
  min-height: 310rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(107, 175, 146, 0.28);
  border-radius: 30rpx;
  background: linear-gradient(135deg, #e9f5ef 0%, #f6f8f5 62%, #f4e7b4 100%);
  box-shadow: var(--pm-shadow-card);
}

.cover-layer { position: absolute; z-index: 0; top: 0; right: 0; bottom: 0; left: 0; overflow: hidden; }
.space-cover { display: block; width: 100%; height: 100%; }
.cover-scrim { position: absolute; top: 0; right: 0; bottom: 0; left: 0; background: linear-gradient(112deg, rgba(246, 248, 245, 0.86) 0%, rgba(246, 248, 245, 0.7) 48%, rgba(246, 248, 245, 0.42) 100%); }
.default-hero { background: radial-gradient(circle at 60% 35%, #f2b84b 0 22rpx, transparent 24rpx), linear-gradient(145deg, #e9f5ef 0%, #f6f8f5 52%, #f4e7b4 100%); }
.space-content { position: relative; z-index: 2; padding: 34rpx; }
.activity-action-anchor { position: absolute; top: 24rpx; right: 24rpx; z-index: 12; }
.activity-action-trigger { display: flex; align-items: center; justify-content: center; width: 58rpx; height: 58rpx; color: var(--pm-primary-dark); font-size: 29rpx; font-weight: 900; letter-spacing: 2rpx; text-shadow: 0 2rpx 8rpx rgba(255, 255, 255, 0.75); }
.activity-action-menu { position: absolute; top: 70rpx; right: 0; width: 188rpx; padding: 8rpx; border: 1rpx solid var(--pm-border); border-radius: 18rpx; background: #fff; box-shadow: 0 18rpx 36rpx rgba(47, 111, 94, 0.16); }
.activity-action-item { display: flex; align-items: center; gap: 12rpx; min-height: 58rpx; padding: 0 12rpx; border-radius: 12rpx; color: var(--pm-text); font-size: 24rpx; font-weight: 700; }
.activity-action-item:active { background: var(--pm-primary-light); }
.activity-action-item.danger { color: var(--pm-danger); }
.activity-action-item.danger:active { background: var(--pm-danger-soft); }
.activity-action-icon { display: inline-flex; align-items: center; justify-content: center; width: 30rpx; color: currentColor; font-size: 32rpx; line-height: 1; }
.activity-action-mask { position: fixed; z-index: 10; top: 0; right: 0; bottom: 0; left: 0; background: transparent; }
.activity-name { margin-top: 18rpx; color: var(--pm-text); font-size: 43rpx; font-weight: 900; line-height: 1.22; }
.activity-meta { margin-top: 10rpx; color: var(--pm-text-muted); font-size: 26rpx; line-height: 1.45; }
.activity-desc { margin-top: 18rpx; max-width: 520rpx; color: var(--pm-text-muted); font-size: 26rpx; line-height: 1.55; }
.share-row { display: flex; gap: 18rpx; margin-top: 24rpx; }
.share-button { min-width: 168rpx; height: 62rpx; font-size: 26rpx; }
.share-button.secondary { margin: 0; line-height: 62rpx; }
.share-button.secondary::after { border: 0; }

.member-card { padding: 24rpx 28rpx; }
.section-heading { display: flex; align-items: center; justify-content: space-between; }
.link-text { color: var(--pm-text-muted); font-size: 24rpx; font-weight: 700; }
.member-strip { display: flex; align-items: center; margin-top: 18rpx; }
.member-dot { width: 56rpx; height: 56rpx; margin-right: -8rpx; border: 4rpx solid #fff; border-radius: 50%; }
.dot-1 { background: #f4e7b4; }
.dot-2 { background: #dff1eb; }
.dot-3 { background: #e5eee8; }
.dot-4 { background: #f7ead8; }
.member-count { margin-left: auto; color: var(--pm-text-muted); font-size: 25rpx; }

.todo-card { padding: 26rpx; border: 1rpx solid #f3e19a; border-radius: 28rpx; background: #fff9e6; box-shadow: var(--pm-shadow-soft); }
.todo-line { margin-top: 12rpx; font-size: 25rpx; color: var(--pm-text); }
.tab-bar { display: grid; grid-template-columns: repeat(4, 1fr); padding: 8rpx; border: 1rpx solid var(--pm-border); border-radius: 24rpx; background: #fff; }
.tab { padding: 16rpx 4rpx; border-radius: 18rpx; text-align: center; color: var(--pm-primary-dark); font-size: 23rpx; font-weight: 700; }
.tab.active { background: var(--pm-primary); color: #fff; }
.section-head { display: flex; align-items: center; justify-content: space-between; }
.section-icon-actions { display: flex; align-items: center; gap: 14rpx; }
.section-icon-button { display: flex; align-items: center; justify-content: center; width: 52rpx; height: 52rpx; color: var(--pm-primary-dark); }
.section-icon-button:active { opacity: 0.58; }
.section-add-icon { font-size: 39rpx; font-weight: 500; line-height: 1; }
.section-list-icon { font-size: 32rpx; font-weight: 700; line-height: 1; }
.compact-row { display: flex; gap: 18rpx; align-items: flex-start; margin-top: 14rpx; padding: 22rpx; font-size: 25rpx; }
.row-main { flex: 1; }
.row-title { font-weight: 800; }
.review { color: #8a6500; font-size: 23rpx; }
.empty-card { margin-top: 16rpx; }
