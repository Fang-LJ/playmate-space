.activity-space-card {
  position: relative;
  overflow: hidden;
  min-height: 310rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(107, 175, 146, 0.28);
  border-radius: 30rpx;
  background: linear-gradient(135deg, #e9f5ef 0%, #f6f8f5 62%, #f4e7b4 100%);
  box-shadow: var(--pm-shadow-card);
}

.cover-layer { position: absolute; right: 0; top: 0; width: 240rpx; height: 180rpx; opacity: 0.42; }
.space-cover { width: 100%; height: 100%; }
.default-hero { background: radial-gradient(circle at 60% 35%, #f2b84b 0 22rpx, transparent 24rpx), linear-gradient(145deg, #e9f5ef 0%, #f6f8f5 52%, #f4e7b4 100%); }
.space-content { position: relative; z-index: 1; padding: 34rpx; }
.activity-name { margin-top: 18rpx; color: var(--pm-text); font-size: 43rpx; font-weight: 900; line-height: 1.22; }
.activity-meta { margin-top: 10rpx; color: var(--pm-text-muted); font-size: 26rpx; line-height: 1.45; }
.activity-desc { margin-top: 18rpx; max-width: 520rpx; color: var(--pm-text-muted); font-size: 26rpx; line-height: 1.55; }
.share-row { display: flex; gap: 18rpx; margin-top: 24rpx; }
.share-button { min-width: 168rpx; height: 62rpx; font-size: 26rpx; }
.share-button.secondary { margin: 0; line-height: 62rpx; }
.share-button.secondary::after { border: 0; }

.member-card { padding: 24rpx 28rpx; }
.section-heading { display: flex; align-items: center; justify-content: space-between; }
.link-text { color: var(--pm-text-muted); font-size: 24rpx; font-weight: 700; }
.member-strip { display: flex; align-items: center; margin-top: 18rpx; }
.member-dot { width: 56rpx; height: 56rpx; margin-right: -8rpx; border: 4rpx solid #fff; border-radius: 50%; }
.dot-1 { background: #f4e7b4; }
.dot-2 { background: #dff1eb; }
.dot-3 { background: #e5eee8; }
.dot-4 { background: #f7ead8; }
.member-count { margin-left: auto; color: var(--pm-text-muted); font-size: 25rpx; }

.todo-card { padding: 26rpx; border: 1rpx solid #f3e19a; border-radius: 28rpx; background: #fff9e6; box-shadow: var(--pm-shadow-soft); }
.todo-line { margin-top: 12rpx; font-size: 25rpx; color: var(--pm-text); }
.tab-bar { display: grid; grid-template-columns: repeat(4, 1fr); padding: 8rpx; border: 1rpx solid var(--pm-border); border-radius: 24rpx; background: #fff; }
.tab { padding: 16rpx 4rpx; border-radius: 18rpx; text-align: center; color: var(--pm-primary-dark); font-size: 23rpx; font-weight: 700; }
.tab.active { background: var(--pm-primary); color: #fff; }
.section-head { display: flex; align-items: center; justify-content: space-between; }
.compact-row { display: flex; gap: 18rpx; align-items: flex-start; margin-top: 14rpx; padding: 22rpx; font-size: 25rpx; }
.row-main { flex: 1; }
.row-title { font-weight: 800; }
.review { color: #8a6500; font-size: 23rpx; }
.empty-card { margin-top: 16rpx; }
.empty-add-button { margin-top: 22rpx; }
.management-card { padding: 24rpx 28rpx; border: 1rpx solid var(--pm-border); border-radius: 24rpx; background: rgba(255,255,255,.72); }
.management-trigger { display: flex; align-items: center; justify-content: space-between; color: var(--pm-primary-dark); font-size: 26rpx; font-weight: 800; }
.management-actions { display: grid; gap: 14rpx; margin-top: 20rpx; }
