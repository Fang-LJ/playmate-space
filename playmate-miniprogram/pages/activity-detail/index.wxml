<view class="page activity-detail-page">
  <view wx:if="{{loading}}" class="section card">正在加载活动空间…</view>
  <view wx:elif="{{errorMessage}}" class="section card">{{errorMessage}}</view>

  <view wx:else>
    <!-- 恢复 P1 改造前的活动空间摘要卡片；下方仍是 P1 协作模块。 -->
    <view class="section hero-section activity-space-card">
      <view class="cover-layer">
        <image wx:if="{{activity.coverUrl}}" class="space-cover" src="{{activity.coverUrl}}" mode="aspectFill" />
        <view wx:else class="space-cover default-hero"></view>
        <view wx:if="{{activity.coverUrl}}" class="cover-scrim"></view>
      </view>
      <view class="space-content">
        <view class="pm-status {{activity.statusClass}}">{{activity.statusText}}</view>
        <view class="activity-name">{{activity.name}}</view>
        <view class="activity-meta">{{activity.typeText}} · {{activity.locationText}}</view>
        <view class="activity-meta">{{activity.dateText}}</view>
        <view class="activity-desc">{{activity.descriptionText}}</view>
        <view wx:if="{{!activity.isReadonly}}" class="share-row">
          <view class="pm-button-like primary share-button" bindtap="copyShareCode">复制分享码</view>
          <button class="pm-button-like secondary share-button secondary" open-type="share">分享邀请</button>
        </view>
      </view>
      <view wx:if="{{activity.isCreator&&!activity.isReadonly}}" class="activity-action-anchor">
        <view class="activity-action-trigger" bindtap="toggleActionMenu" aria-label="活动操作">•••</view>
        <view wx:if="{{actionMenuVisible}}" class="activity-action-menu" catchtap="stopActionMenu">
          <view class="activity-action-item" bindtap="goEdit"><text class="activity-action-icon">✎</text><text>编辑活动</text></view>
          <view class="activity-action-item" bindtap="confirmEnd"><text class="activity-action-icon">✓</text><text>结束活动</text></view>
          <view class="activity-action-item danger" bindtap="confirmCancel"><text class="activity-action-icon">×</text><text>取消活动</text></view>
        </view>
      </view>
    </view>

    <view wx:if="{{actionMenuVisible}}" class="activity-action-mask" catchtap="closeActionMenu"></view>

    <view class="section card member-card" bindtap="goMembers">
      <view class="section-heading">
        <view class="section-title">参与成员</view>
        <view class="link-text">查看全部</view>
      </view>
      <view class="member-strip">
        <block wx:for="{{members}}" wx:key="memberId">
          <image wx:if="{{item.avatarUrl}}" class="member-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
          <view wx:else class="member-avatar member-avatar-placeholder">{{item.avatarText}}</view>
        </block>
        <view class="member-count">{{activity.memberCount}} 人参与</view>
      </view>
    </view>

    <view wx:if="{{summary.todoCount}}" class="section todo-card">
      <view class="section-title">待处理 {{summary.todoCount}}</view>
      <view wx:for="{{summary.todos}}" wx:key="title" class="todo-line" data-target-type="{{item.targetType}}" data-target-id="{{item.targetId}}" bindtap="todo">• {{item.title}}</view>
    </view>

    <view class="section tab-bar">
      <view class="tab {{activeTab==='ITINERARIES'?'active':''}}" data-tab="ITINERARIES" bindtap="tab">行程</view>
      <view class="tab {{activeTab==='POLLS'?'active':''}}" data-tab="POLLS" bindtap="tab">投票 {{summary.activePollCount||''}}</view>
      <view class="tab {{activeTab==='COSTS'?'active':''}}" data-tab="COSTS" bindtap="tab">费用</view>
      <view class="tab {{activeTab==='PHOTOS'?'active':''}}" data-tab="PHOTOS" bindtap="tab">照片</view>
    </view>

    <view wx:if="{{activeTab==='ITINERARIES'}}" class="section">
      <view class="section-head">
        <view class="section-title">行程安排</view>
        <view class="section-icon-actions">
          <view wx:if="{{!activity.isReadonly}}" class="section-icon-button" bindtap="newItinerary" aria-label="新增行程"><text class="section-add-icon">+</text></view>
          <view class="section-icon-button" bindtap="goItineraries" aria-label="查看全部行程"><text class="section-list-icon">☰</text></view>
        </view>
      </view>
      <view wx:if="{{!itineraries.length}}" class="card empty-card"><view>还没有行程安排</view><view class="section-desc">从集合、交通或第一站开始添加。</view></view>
      <view wx:for="{{itineraries}}" wx:key="itineraryId" class="card compact-row" data-id="{{item.itineraryId}}" bindtap="goItinerary"><view>{{item.timeText}}</view><view class="row-main"><view class="row-title">{{item.title}} <text class="itinerary-type-mark">{{item.typeText}}</text></view><view class="muted">{{item.summaryText}} · {{item.planningStatusText}}</view></view></view>
    </view>

    <view wx:if="{{activeTab==='POLLS'}}" class="section">
      <view class="section-head"><view class="section-title">投票决策</view><view class="pm-link" bindtap="goPolls">查看全部</view></view>
      <view wx:if="{{!polls.length}}" class="card empty-card">还没有投票，去创建一个吧。</view>
      <view wx:for="{{polls}}" wx:key="pollId" class="card compact-row" data-id="{{item.pollId}}" bindtap="goPoll"><view class="row-main"><view class="row-title">{{item.title}}</view><view class="muted">{{item.statusText}} · {{item.participantCount}} 人参与</view></view><view wx:if="{{item.resultApplyStatus==='REVIEW_REQUIRED'}}" class="review">{{item.resultApplyText}}</view></view>
      <button wx:if="{{!activity.isReadonly}}" class="pm-native-button primary section" bindtap="newPoll">创建投票</button>
    </view>

    <view wx:if="{{activeTab==='COSTS'||activeTab==='PHOTOS'}}" class="section card empty-card"><view class="section-title">{{activeTab==='COSTS'?'费用管理':'照片墙'}}将在后续阶段开放</view><view class="section-desc">当前不展示伪造数据，活动协作会在后续模块继续完善。</view></view>
  </view>
</view>
