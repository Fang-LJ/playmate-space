<view class="page">
  <view wx:if="{{loading}}" class="section card stack">
    <view class="empty-title">正在加载活动</view>
    <view class="empty-desc">正在打开这个活动空间。</view>
  </view>

  <view wx:elif="{{errorMessage}}" class="section card stack">
    <view class="empty-title">加载失败</view>
    <view class="empty-desc">{{errorMessage}}</view>
    <button class="pm-native-button primary" bindtap="retryLoad">重新加载</button>
  </view>

  <block wx:else>
    <view class="page-title">活动详情</view>

    <view class="section activity-space-card">
      <view class="cover-layer">
        <image wx:if="{{activity.coverUrl}}" class="space-cover" src="{{activity.coverUrl}}" mode="aspectFill" />
        <view wx:else class="space-cover default-hero"></view>
      </view>
      <view class="space-content">
        <view class="pm-status {{activity.statusClass}}">{{activity.statusText}}</view>
        <view class="activity-name">{{activity.name}}</view>
        <view class="activity-meta">{{activity.typeText}} · {{activity.locationText}}</view>
        <view class="activity-meta">{{activity.dateText}}</view>
        <view class="activity-desc">{{activity.descriptionText}}</view>
        <view wx:if="{{!activity.isCanceled}}" class="share-row">
          <view class="pm-button-like primary share-button" bindtap="copyShareCode">复制分享码</view>
          <button class="pm-button-like secondary share-button secondary" open-type="share">分享邀请</button>
        </view>
      </view>
    </view>

    <view class="section card member-card" bindtap="showTodo" data-name="成员" data-route="members">
      <view class="section-heading">
        <view class="section-title">成员</view>
        <view class="link-text">查看全部</view>
      </view>
      <view class="member-strip">
        <view class="member-dot dot-1"></view>
        <view class="member-dot dot-2"></view>
        <view class="member-dot dot-3"></view>
        <view class="member-dot dot-4"></view>
        <view class="member-count">{{activity.memberCount}} 人参与</view>
      </view>
    </view>

    <view class="section card summary-card">
      <view class="summary-row">
        <view>
          <view class="summary-label">详细地址</view>
          <view class="summary-value">{{activity.addressText}}</view>
        </view>
        <view>
          <view class="summary-label">我的角色</view>
          <view class="summary-value">{{activity.currentUserRoleText}}</view>
        </view>
      </view>
    </view>

    <view class="section module-section">
      <view class="module-title">出发前：成员 / 行程 / 投票</view>
      <view class="module-row">
        <view
          wx:for="{{beforeModules}}"
          wx:key="name"
          class="module-card {{item.enabled ? 'open' : 'disabled'}}"
          data-name="{{item.name}}"
          data-route="{{item.route}}"
          bindtap="showTodo"
        >
          <view class="module-icon {{item.tone}}">{{item.shortName}}</view>
          <view class="module-name">{{item.name}}</view>
          <view class="module-desc">{{item.desc}}</view>
        </view>
      </view>
    </view>

    <view class="section module-section">
      <view class="module-title">活动中 / 活动后</view>
      <view class="module-row">
        <view
          wx:for="{{afterModules}}"
          wx:key="name"
          class="module-card {{item.enabled ? 'open' : 'disabled'}}"
          data-name="{{item.name}}"
          data-route="{{item.route}}"
          bindtap="showTodo"
        >
          <view class="module-icon {{item.tone}}">{{item.shortName}}</view>
          <view class="module-name">{{item.name}}</view>
          <view class="module-desc">{{item.desc}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{activity.isCreator && !activity.isCanceled}}" class="section card action-card">
      <view class="section-title">创建者操作</view>
      <view wx:if="{{activity.isPlanning}}" class="action-row">
        <view class="pm-button-like primary action-button" bindtap="goEdit">编辑活动</view>
        <view class="pm-button-like secondary action-button" bindtap="confirmEnd">结束活动</view>
        <view class="pm-button-like danger action-button" bindtap="confirmCancel">取消活动</view>
      </view>
      <view wx:elif="{{activity.isEnded}}" class="action-row">
        <view class="pm-button-like primary action-button" bindtap="goEdit">编辑活动</view>
      </view>
    </view>

    <view wx:if="{{activity.isCanceled}}" class="section canceled-note">
      活动已取消，当前仅可查看历史信息。
    </view>
  </block>
</view>
