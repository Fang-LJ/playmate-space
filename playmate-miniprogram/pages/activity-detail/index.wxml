<view class="page"><view wx:if="{{loading}}" class="section card">正在加载活动空间…</view><view wx:elif="{{errorMessage}}" class="section card">{{errorMessage}}</view><view wx:else><view class="page-title">活动详情</view><view class="section pm-hero-card"><view class="pm-status">{{activity.statusText}}</view><view class="hero-name">{{activity.name}}</view><view class="section-desc">{{activity.type}} · {{activity.locationName||'地点待定'}} · {{activity.startDate}}–{{activity.endDate}}</view><view class="section-desc">{{activity.memberCount}} 位成员一起规划这次活动</view><button wx:if="{{!activity.isReadonly}}" class="pm-native-button primary share-btn" open-type="share">分享邀请</button></view><view class="section card members" bindtap="goMembers"><view class="section-title">参与成员</view><view class="section-desc">{{activity.memberCount}} 人参与 · 查看全部</view></view><view wx:if="{{summary.todoCount}}" class="section todo-card"><view class="section-title">待处理 {{summary.todoCount}}</view><view wx:for="{{summary.todos}}" wx:key="title" class="todo-line" data-target-type="{{item.targetType}}" data-target-id="{{item.targetId}}" bindtap="todo">• {{item.title}}</view></view><view class="section tab-bar"><view class="tab {{activeTab==='ITINERARIES'?'active':''}}" data-tab="ITINERARIES" bindtap="tab">行程</view><view class="tab {{activeTab==='POLLS'?'active':''}}" data-tab="POLLS" bindtap="tab">投票 {{summary.activePollCount||''}}</view><view class="tab {{activeTab==='COSTS'?'active':''}}" data-tab="COSTS" bindtap="tab">费用</view><view class="tab {{activeTab==='PHOTOS'?'active':''}}" data-tab="PHOTOS" bindtap="tab">照片</view></view><view wx:if="{{activeTab==='ITINERARIES'}}" class="section"><view class="section-head"><view class="section-title">行程安排</view><view class="pm-link" bindtap="goItineraries">查看全部</view></view><view wx:if="{{!itineraries.length}}" class="card empty-card"><view>还没有行程安排</view><view class="section-desc">从集合、交通或第一站开始添加。</view></view><view wx:for="{{itineraries}}" wx:key="itineraryId" class="card compact-row" data-id="{{item.itineraryId}}" bindtap="goItinerary"><view>{{item.startTime||'全天'}}</view><view class="row-main"><view>{{item.title}}</view><view class="muted">{{item.locationName||'地点待定'}} · {{item.planningStatus}}</view></view></view><button wx:if="{{!activity.isReadonly}}" class="pm-native-button primary section" bindtap="newItinerary">新增行程</button></view><view wx:if="{{activeTab==='POLLS'}}" class="section"><view class="section-head"><view class="section-title">投票决策</view><view class="pm-link" bindtap="goPolls">查看全部</view></view><view wx:if="{{!polls.length}}" class="card empty-card">还没有投票，去创建一个吧。</view><view wx:for="{{polls}}" wx:key="pollId" class="card compact-row" data-id="{{item.pollId}}" bindtap="goPoll"><view class="row-main"><view>{{item.title}}</view><view class="muted">{{item.status}} · {{item.participantCount}} 人参与</view></view><view wx:if="{{item.resultApplyStatus==='REVIEW_REQUIRED'}}" class="review">待确认</view></view><button wx:if="{{!activity.isReadonly}}" class="pm-native-button primary section" bindtap="newPoll">创建投票</button></view><view wx:if="{{activeTab==='COSTS'||activeTab==='PHOTOS'}}" class="section card empty-card"><view class="section-title">{{activeTab==='COSTS'?'费用管理':'照片墙'}}将在后续阶段开放</view><view class="section-desc">当前不展示伪造数据，活动协作会在后续模块继续完善。</view></view><view wx:if="{{activity.isCreator&&!activity.isReadonly}}" class="section action-row"><button class="pm-native-button secondary" bindtap="goEdit">编辑活动</button><button class="pm-native-button secondary" bindtap="confirmEnd">结束活动</button><button class="pm-native-button danger-ghost" bindtap="confirmCancel">取消活动</button></view></view></view>
