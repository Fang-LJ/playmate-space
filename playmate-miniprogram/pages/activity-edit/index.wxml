<view class="page">
  <view wx:if="{{loading}}" class="section card stack">
    <view class="empty-title">正在加载活动</view>
    <view class="empty-desc">正在读取活动信息。</view>
  </view>

  <view wx:elif="{{errorMessage}}" class="section card stack">
    <view class="empty-title">加载失败</view>
    <view class="empty-desc">{{errorMessage}}</view>
    <button class="pm-native-button primary" bindtap="retryLoad">重新加载</button>
  </view>

  <block wx:else>
    <view class="page-title">编辑活动</view>
    <view class="page-subtitle">{{isCanceled ? '已取消活动不可编辑。' : (isEnded ? '已结束活动只允许修改封面和描述。' : '更新活动的基础信息。')}}</view>

    <view wx:if="{{isCanceled}}" class="section card stack">
      <view class="empty-title">已取消活动不可编辑</view>
      <view class="empty-desc">当前活动已经取消，只能查看历史信息，不能再修改活动内容。</view>
      <button class="pm-native-button primary" bindtap="cancelBack">返回详情</button>
    </view>

    <view wx:else class="section card pm-form-card">
      <view>
        <view class="section-title">封面</view>
        <view class="section-desc">已结束活动也可以继续调整封面和描述。</view>
      </view>
      <view class="cover-card" bindtap="chooseCover">
        <image wx:if="{{form.coverUrl}}" class="cover-preview" src="{{form.coverUrl}}" mode="aspectFill" />
        <view wx:else class="cover-placeholder">
          <view class="cover-title">上传活动封面</view>
          <view class="cover-desc">可选，适合放一张旅行或聚会照片</view>
        </view>
        <view class="cover-action">{{uploading ? '上传中...' : '更换封面'}}</view>
      </view>
    </view>

    <view wx:if="{{!isCanceled}}" class="section card pm-form-card">
      <block wx:if="{{!isEnded}}">
        <view>
          <view class="section-title">基础信息</view>
          <view class="section-desc">更新后成员会在活动详情里看到最新信息。</view>
        </view>

        <view class="pm-field">
          <view class="pm-label">活动名称</view>
          <input class="pm-input" placeholder="例如：周末杭州两日游" value="{{form.name}}" data-field="name" bindinput="handleInput" />
        </view>

        <view class="pm-field">
          <view class="pm-label">活动类型</view>
          <view class="type-grid">
            <view
              wx:for="{{typeOptions}}"
              wx:key="value"
              class="type-chip {{form.type === item.value ? 'active' : ''}}"
              data-value="{{item.value}}"
              bindtap="handleTypeTap"
            >
              {{item.label}}
            </view>
          </view>
        </view>

        <view class="pm-field">
          <view class="pm-label">地点名称</view>
          <input class="pm-input" placeholder="例如：杭州 / 朋友家 / 公司" value="{{form.locationName}}" data-field="locationName" bindinput="handleInput" />
        </view>

        <view class="pm-field">
          <view class="pm-label">详细地址</view>
          <input class="pm-input" placeholder="可选，不做地图定位" value="{{form.address}}" data-field="address" bindinput="handleInput" />
        </view>

        <view class="date-row">
          <view class="pm-field half">
            <view class="pm-label">开始日期</view>
            <picker mode="date" value="{{form.startDate}}" data-field="startDate" bindchange="handleDateChange">
              <view class="date-box">
                <view class="date-label">开始</view>
                <view class="date-value">{{form.startDate}}</view>
              </view>
            </picker>
          </view>
          <view class="pm-field half">
            <view class="pm-label">结束日期</view>
            <picker mode="date" value="{{form.endDate}}" data-field="endDate" bindchange="handleDateChange">
              <view class="date-box">
                <view class="date-label">结束</view>
                <view class="date-value">{{form.endDate}}</view>
              </view>
            </picker>
          </view>
        </view>
      </block>

      <view class="pm-field">
        <view class="pm-label">活动描述</view>
        <textarea class="pm-textarea" placeholder="简单写一下这次活动安排" value="{{form.description}}" data-field="description" bindinput="handleInput" maxlength="1000" />
      </view>
    </view>

    <view wx:if="{{!isCanceled}}" class="pm-bottom-bar">
      <view class="pm-secondary-action">
        <button class="pm-native-button secondary" bindtap="cancelBack" disabled="{{submitting || uploading}}">取消</button>
      </view>
      <view class="pm-primary-action">
        <button class="pm-native-button primary" bindtap="submitEdit" loading="{{submitting}}" disabled="{{uploading}}">{{submitting ? '保存中...' : '保存'}}</button>
      </view>
    </view>
  </block>
</view>
