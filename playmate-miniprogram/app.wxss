page {
  --pm-bg: #f6f8f5;
  --pm-bg-soft: #e9f5ef;
  --pm-card: #ffffff;
  --pm-primary: #6baf92;
  --pm-primary-dark: #2f6f5e;
  --pm-primary-light: #e9f5ef;
  --pm-warning: #f2b84b;
  --pm-warning-soft: #fff6dc;
  --pm-accent: #f2b84b;
  --pm-accent-soft: #f4e7b4;
  --pm-text: #1f2a24;
  --pm-text-muted: #6f7c75;
  --pm-border: #e1e8e3;
  --pm-danger: #d94c4c;
  --pm-danger-soft: #f7eeee;
  --pm-success: #4f9c7a;
  --pm-success-soft: #e9f5ef;
  --pm-radius-card: 30rpx;
  --pm-radius-button: 18rpx;
  --pm-radius-control: 22rpx;
  --pm-shadow-card: 0 14rpx 36rpx rgba(47, 111, 94, 0.07);
  --pm-shadow-soft: 0 8rpx 24rpx rgba(47, 111, 94, 0.05);
  --td-brand-color: #6baf92;
  --td-brand-color-active: #2f6f5e;
  --td-brand-color-light: #e9f5ef;
  --td-brand-color-disabled: #b9d8c9;
  --td-button-primary-bg-color: #6baf92;
  --td-button-primary-border-color: #6baf92;
  --td-button-primary-active-bg-color: #2f6f5e;
  --td-button-primary-active-border-color: #2f6f5e;
  --td-button-primary-outline-color: #2f6f5e;
  --td-button-primary-outline-border-color: #9bcbb7;
  --td-tab-bar-active-color: #2f6f5e;
  min-height: 100vh;
  background: var(--pm-bg);
  color: var(--pm-text);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 36rpx 32rpx;
  background: var(--pm-bg);
}

.page-title {
  color: var(--pm-text);
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.25;
}

.page-subtitle {
  margin-top: 12rpx;
  color: var(--pm-text-muted);
  font-size: 28rpx;
  line-height: 1.5;
}

.section {
  margin-top: 32rpx;
}

.card {
  box-sizing: border-box;
  padding: 32rpx;
  background: var(--pm-card);
  border: 1rpx solid var(--pm-border);
  border-radius: var(--pm-radius-card);
  box-shadow: var(--pm-shadow-card);
}

.pm-hero-card {
  box-sizing: border-box;
  padding: 34rpx;
  border: 1rpx solid rgba(107, 175, 146, 0.24);
  border-radius: var(--pm-radius-card);
  background: linear-gradient(135deg, #ffffff 0%, #f7fbf8 52%, #eef7f2 100%);
  box-shadow: var(--pm-shadow-card);
}

.pm-link {
  color: var(--pm-primary-dark);
  font-size: 25rpx;
  font-weight: 700;
}

.pm-button-like {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  box-sizing: border-box;
  padding: 0 28rpx;
  border-radius: var(--pm-radius-button);
  font-size: 27rpx;
  font-weight: 800;
}

.pm-button-like.primary {
  background: var(--pm-primary);
  color: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(107, 175, 146, 0.2);
}

.pm-button-like.secondary {
  border: 1rpx solid rgba(107, 175, 146, 0.34);
  background: rgba(255, 255, 255, 0.82);
  color: var(--pm-primary-dark);
}

.pm-button-like.danger {
  border: 1rpx solid rgba(217, 76, 76, 0.28);
  background: var(--pm-danger-soft);
  color: var(--pm-danger);
}

.pm-native-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  box-sizing: border-box;
  padding: 0 28rpx;
  border-radius: var(--pm-radius-button);
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1;
}

.pm-native-button::after {
  border: 0;
}

.pm-native-button.primary {
  background: var(--pm-primary);
  color: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(107, 175, 146, 0.2);
}

.pm-native-button.secondary {
  border: 1rpx solid rgba(107, 175, 146, 0.34);
  background: #ffffff;
  color: var(--pm-primary-dark);
}

.pm-native-button.text {
  min-height: 76rpx;
  background: transparent;
  color: var(--pm-text-muted);
  font-weight: 700;
}

.pm-native-button.danger-ghost {
  border: 1rpx solid rgba(217, 76, 76, 0.28);
  background: #ffffff;
  color: var(--pm-danger);
}

.pm-native-button[disabled] {
  opacity: 0.58;
}

.muted {
  color: var(--pm-text-muted);
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section-title {
  color: var(--pm-text);
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.section-desc {
  margin-top: 8rpx;
  color: var(--pm-text-muted);
  font-size: 25rpx;
  line-height: 1.45;
}

.pm-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  box-sizing: border-box;
  padding: 0 20rpx;
  border: 1rpx solid var(--pm-border);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  color: var(--pm-text-muted);
  font-size: 24rpx;
  font-weight: 600;
}

.pm-chip.active {
  border-color: var(--pm-primary);
  background: var(--pm-primary-light);
  color: var(--pm-primary-dark);
}

.pm-status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 46rpx;
  box-sizing: border-box;
  padding: 0 18rpx;
  border: 1rpx solid rgba(107, 175, 146, 0.38);
  border-radius: 999rpx;
  background: var(--pm-primary-light);
  color: var(--pm-primary-dark);
  font-size: 23rpx;
  font-weight: 700;
}

.pm-status.ended,
.pm-status.canceled {
  border-color: #dfe7e2;
  background: #f1f5f2;
  color: var(--pm-text-muted);
}

.pm-status.ongoing {
  border-color: rgba(242, 184, 75, 0.52);
  background: #fff7df;
  color: #8a6500;
}

.pm-form-card {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.pm-field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.pm-label {
  color: var(--pm-text);
  font-size: 26rpx;
  font-weight: 700;
}

.pm-input,
.pm-picker,
.pm-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 88rpx;
  padding: 22rpx 24rpx;
  border-radius: var(--pm-radius-control);
  background: rgba(246, 248, 245, 0.95);
  border: 1rpx solid var(--pm-border);
  color: var(--pm-text);
  font-size: 28rpx;
}

.pm-textarea {
  height: 180rpx;
  line-height: 1.5;
}

.pm-bottom-bar {
  display: flex;
  gap: 20rpx;
  padding: 28rpx 0 calc(28rpx + env(safe-area-inset-bottom));
}

.pm-secondary-action {
  width: 180rpx;
}

.pm-primary-action {
  flex: 1;
}
